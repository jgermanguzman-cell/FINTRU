function repararValidacionesPresupuestoMovimientos() {
  const ss = SpreadsheetApp.getActiveSpreadsheet();

  const shPresupuesto = ss.getSheetByName("Presupuesto");
  const shMovimientos = ss.getSheetByName("Movimientos");
  const shMetodos = ss.getSheetByName("Métodos de Pago");

  if (!shPresupuesto || !shMovimientos || !shMetodos) {
    throw new Error("Faltan hojas requeridas: Presupuesto, Movimientos o Métodos de Pago.");
  }

  const maxRowsPresupuesto = shPresupuesto.getMaxRows() - 1;
  const maxRowsMovimientos = shMovimientos.getMaxRows() - 1;

  const ruleMetodosPago = SpreadsheetApp.newDataValidation()
    .requireValueInRange(shMetodos.getRange("J2:J"), true)
    .setAllowInvalid(false)
    .build();

  const ruleSoloCuentas = SpreadsheetApp.newDataValidation()
    .requireValueInRange(shMetodos.getRange("L2:L"), true)
    .setAllowInvalid(false)
    .build();

  const ruleSoloTarjetas = SpreadsheetApp.newDataValidation()
    .requireValueInRange(shMetodos.getRange("N2:N"), true)
    .setAllowInvalid(false)
    .build();

  const ruleSoloDeudas = SpreadsheetApp.newDataValidation()
    .requireValueInRange(shMetodos.getRange("P2:P"), true)
    .setAllowInvalid(false)
    .build();

  aplicarValidacionRangoNombradoPorHeaderAtajos_(ss, shPresupuesto, "Moneda", "cat_monedas", maxRowsPresupuesto);
  aplicarValidacionRangoNombradoPorHeaderAtajos_(ss, shPresupuesto, "Naturaleza", "cat_naturaleza", maxRowsPresupuesto);
  aplicarValidacionRangoNombradoPorHeaderAtajos_(ss, shPresupuesto, "Categoria", "cat_categorias", maxRowsPresupuesto);
  aplicarValidacionRangoNombradoPorHeaderAtajos_(ss, shPresupuesto, "Tipo", "cat_tipo_presupuesto", maxRowsPresupuesto);
  aplicarValidacionRangoNombradoPorHeaderAtajos_(ss, shPresupuesto, "Activo", "cat_estado", maxRowsPresupuesto);
  aplicarValidacionRangoNombradoPorHeaderAtajos_(ss, shPresupuesto, "Versión presupuesto", "cat_version_presupuesto", maxRowsPresupuesto);
  aplicarValidacionRangoNombradoPorHeaderAtajos_(ss, shPresupuesto, "Origen del registro", "cat_origen_registro", maxRowsPresupuesto);
  aplicarValidacionRangoNombradoPorHeaderAtajos_(ss, shPresupuesto, "Estado de ejecución", "cat_estado_ejecucion", maxRowsPresupuesto);

  aplicarValidacionPorHeaderAtajos_(shPresupuesto, "Método de Pago", ruleMetodosPago, maxRowsPresupuesto);
  aplicarValidacionPorHeaderAtajos_(shPresupuesto, "Destino", ruleSoloCuentas, maxRowsPresupuesto);
  aplicarValidacionPorHeaderAtajos_(shPresupuesto, "Destino_TC", ruleSoloTarjetas, maxRowsPresupuesto);
  aplicarValidacionPorHeaderAtajos_(shPresupuesto, "Destino_Deuda", ruleSoloDeudas, maxRowsPresupuesto);

  aplicarValidacionRangoNombradoPorHeaderAtajos_(ss, shMovimientos, "Moneda", "cat_monedas", maxRowsMovimientos);
  aplicarValidacionRangoNombradoPorHeaderAtajos_(ss, shMovimientos, "Naturaleza", "cat_naturaleza", maxRowsMovimientos);
  aplicarValidacionRangoNombradoPorHeaderAtajos_(ss, shMovimientos, "Categoría", "cat_categorias", maxRowsMovimientos);
  aplicarValidacionPorHeaderAtajos_(shMovimientos, "Método de pago", ruleMetodosPago, maxRowsMovimientos);
  aplicarValidacionPorHeaderAtajos_(shMovimientos, "Destino", ruleSoloCuentas, maxRowsMovimientos);
  aplicarValidacionPorHeaderAtajos_(shMovimientos, "Destino_TC", ruleSoloTarjetas, maxRowsMovimientos);
  aplicarValidacionPorHeaderAtajos_(shMovimientos, "Destino_Deuda", ruleSoloDeudas, maxRowsMovimientos);

  const metasActivas = obtenerMetasActivasParaValidacionAtajos_();
  aplicarValidacionListaPorHeaderAtajos_(shPresupuesto, "Meta", metasActivas, maxRowsPresupuesto);
  aplicarValidacionListaPorHeaderAtajos_(shMovimientos, "Meta", metasActivas, maxRowsMovimientos);
}

function aplicarValidacionEtiquetaMovimiento_(shMovimientos, targetRow) {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const shCatalogos = ss.getSheetByName("Catálogos");

  if (!shCatalogos) {
    throw new Error("No existe la hoja Catálogos.");
  }

  const categoria = String(leerValorPorHeaderAtajos_(shMovimientos, targetRow, "Categoría") || leerValorPorHeaderAtajos_(shMovimientos, targetRow, "Categoria")).trim();
  const naturaleza = String(leerValorPorHeaderAtajos_(shMovimientos, targetRow, "Naturaleza")).trim();

  const etiquetaCol = buscarColumnaPorHeaderAtajos_(shMovimientos, "Etiqueta");
  if (!etiquetaCol) return;

  const etiquetaCell = shMovimientos.getRange(targetRow, etiquetaCol);
  etiquetaCell.clearDataValidations();

  if (!categoria || !naturaleza) return;

  const lastRow = shCatalogos.getLastRow();
  if (lastRow < 14) return;

  const data = shCatalogos.getRange(14, 1, lastRow - 13, 3).getValues();

  let etiquetas = [];

  if (naturaleza === "Ingreso") {
    etiquetas = data
      .filter(row =>
        String(row[0]).trim() === "N/A" &&
        String(row[2]).trim() === "Activo" &&
        ["Activo", "Pasivo", "Préstamo recibido"].includes(String(row[1]).trim())
      )
      .map(row => row[1]);
  } else {
    etiquetas = data
      .filter(row =>
        String(row[0]).trim() === categoria &&
        String(row[2]).trim() === "Activo"
      )
      .map(row => row[1]);
  }

  etiquetas = [...new Set(etiquetas)].filter(Boolean);

  if (etiquetas.length === 0) return;

  const rule = SpreadsheetApp.newDataValidation()
    .requireValueInList(etiquetas, true)
    .setAllowInvalid(false)
    .build();

  etiquetaCell.setDataValidation(rule);
}

function aplicarValidacionMetaMovimiento_(shMovimientos, targetRow) {
  const metaCol = buscarColumnaPorHeaderAtajos_(shMovimientos, "Meta");
  if (!metaCol) return;

  const metasActivas = obtenerMetasActivasParaValidacionAtajos_();
  const cell = shMovimientos.getRange(targetRow, metaCol);

  if (!metasActivas || metasActivas.length === 0) {
    cell.clearDataValidations();
    return;
  }

  const rule = SpreadsheetApp.newDataValidation()
    .requireValueInList([...new Set(metasActivas.filter(String))], true)
    .setAllowInvalid(false)
    .build();

  cell.setDataValidation(rule);
}

function obtenerMetasActivasParaValidacionAtajos_() {
  if (typeof obtenerMetasActivasMetas_ === "function") {
    return obtenerMetasActivasMetas_(SpreadsheetApp.getActiveSpreadsheet());
  }

  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const shMetas = ss.getSheetByName("Metas");

  if (!shMetas) return [];

  const lastRow = shMetas.getLastRow();
  if (lastRow < 2) return [];

  const lastCol = shMetas.getLastColumn();
  const headers = shMetas.getRange(1, 1, 1, lastCol).getValues()[0];
  const map = crearHeaderMapAtajos_(headers);

  const data = shMetas.getRange(2, 1, lastRow - 1, lastCol).getValues();

  return data
    .filter(row => {
      const nombre = leerCampoAtajos_(row, map, ["Nombre"]);
      const estado = String(leerCampoAtajos_(row, map, ["Estado"])).trim().toLowerCase();

      if (!nombre) return false;

      return estado === "activa" ||
        estado === "activo" ||
        estado === "vigente";
    })
    .map(row => String(leerCampoAtajos_(row, map, ["Nombre"])).trim());
}

function aplicarValidacionRangoNombradoPorHeaderAtajos_(ss, sheet, headerName, rangeName, maxRows) {
  const namedRange = ss.getRangeByName(rangeName);
  if (!namedRange) return;

  const rule = SpreadsheetApp.newDataValidation()
    .requireValueInRange(namedRange, true)
    .setAllowInvalid(false)
    .build();

  aplicarValidacionPorHeaderAtajos_(sheet, headerName, rule, maxRows);
}

function aplicarValidacionPorHeaderAtajos_(sheet, headerName, rule, maxRows) {
  const col = buscarColumnaPorHeaderAtajos_(sheet, headerName);
  if (!col) return;

  sheet.getRange(2, col, maxRows, 1).setDataValidation(rule);
}

function aplicarValidacionListaPorHeaderAtajos_(sheet, headerName, values, maxRows) {
  const col = buscarColumnaPorHeaderAtajos_(sheet, headerName);
  if (!col) return;

  const range = sheet.getRange(2, col, maxRows, 1);

  if (!values || values.length === 0) {
    range.clearDataValidations();
    return;
  }

  const rule = SpreadsheetApp.newDataValidation()
    .requireValueInList([...new Set(values.filter(String))], true)
    .setAllowInvalid(false)
    .build();

  range.setDataValidation(rule);
}

function escribirValorPorHeaderAtajos_(sheet, rowNumber, headerName, value) {
  const col = buscarColumnaPorHeaderAtajos_(sheet, headerName);

  if (!col) {
    throw new Error(`No se encontró la columna "${headerName}" en la hoja ${sheet.getName()}.`);
  }

  sheet.getRange(rowNumber, col).setValue(value);
}

function leerValorPorHeaderAtajos_(sheet, rowNumber, headerName) {
  const col = buscarColumnaPorHeaderAtajos_(sheet, headerName);
  if (!col) return "";

  return sheet.getRange(rowNumber, col).getValue();
}

function buscarColumnaPorHeaderAtajos_(sheet, headerName) {
  const lastCol = sheet.getLastColumn();
  if (lastCol < 1) return null;

  const headers = sheet.getRange(1, 1, 1, lastCol).getValues()[0];
  const map = crearHeaderMapAtajos_(headers);

  const index = obtenerIndiceHeaderAtajos_(map, [headerName]);

  return index === null ? null : index + 1;
}

function crearHeaderMapAtajos_(headers) {
  const map = {};

  headers.forEach((header, index) => {
    const key = normalizarHeaderAtajos_(header);
    if (key) {
      map[key] = index;
    }
  });

  return map;
}

function obtenerIndiceHeaderAtajos_(map, posiblesNombres) {
  for (const nombre of posiblesNombres) {
    const key = normalizarHeaderAtajos_(nombre);

    if (Object.prototype.hasOwnProperty.call(map, key)) {
      return map[key];
    }
  }

  return null;
}

function leerCampoAtajos_(row, map, posiblesNombres) {
  const index = obtenerIndiceHeaderAtajos_(map, posiblesNombres);
  return index === null ? "" : row[index];
}

function escribirCampoAtajos_(row, map, posiblesNombres, value) {
  const index = obtenerIndiceHeaderAtajos_(map, posiblesNombres);
  if (index !== null) {
    row[index] = value;
  }
}

function normalizarHeaderAtajos_(value) {
  return String(value || "")
    .trim()
    .toLowerCase()
    .normalize("NFD")
    .replace(/[\u0300-\u036f]/g, "")
    .replace(/_/g, " ")
    .replace(/\s+/g, " ");
}
