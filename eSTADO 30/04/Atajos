function configurarHojaAtajos() {
  refrescarAtajosDesdePresupuesto();
  crearTriggerAtajos();
}

function refrescarAtajosDesdePresupuesto() {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const shPresupuesto = ss.getSheetByName("Presupuesto");

  if (!shPresupuesto) {
    throw new Error("No existe la hoja Presupuesto.");
  }

  let shAtajos = ss.getSheetByName("Atajos");
  if (!shAtajos) {
    shAtajos = ss.insertSheet("Atajos");
  }

  shAtajos.clearContents();
  shAtajos.getDataRange().clearDataValidations();

  try {
    shAtajos.showColumns(5);
  } catch (err) {}

  shAtajos.getRange(1, 1, 1, 5).setValues([[
    "Concepto",
    "Monto",
    "Método de Pago",
    "Registrar ahora",
    "Fila Presupuesto"
  ]]);

  const lastRow = shPresupuesto.getLastRow();
  const lastCol = shPresupuesto.getLastColumn();

  if (lastRow < 2) {
    shAtajos.hideColumns(5);
    return;
  }

  const headers = shPresupuesto.getRange(1, 1, 1, lastCol).getValues()[0];
  const map = crearHeaderMapAtajos_(headers);

  const data = shPresupuesto.getRange(2, 1, lastRow - 1, lastCol).getValues();
  const filasAtajos = [];

  data.forEach((row, index) => {
    const filaPresupuesto = index + 2;

    const concepto = leerCampoAtajos_(row, map, ["Concepto"]);
    const monto = leerCampoAtajos_(row, map, ["Monto"]);
    const metodoPago = leerCampoAtajos_(row, map, ["Método de Pago", "Metodo de Pago"]);
    const tipo = String(leerCampoAtajos_(row, map, ["Tipo"])).trim();
    const activo = String(leerCampoAtajos_(row, map, ["Activo"])).trim();

    if (!concepto) return;
    if (tipo !== "Atajo") return;
    if (activo !== "Activo") return;

    filasAtajos.push([
      concepto,
      monto,
      metodoPago,
      false,
      filaPresupuesto
    ]);
  });

  if (filasAtajos.length > 0) {
    shAtajos.getRange(2, 1, filasAtajos.length, 5).setValues(filasAtajos);
    shAtajos.getRange(2, 4, filasAtajos.length, 1).insertCheckboxes();

    const shMetodos = ss.getSheetByName("Métodos de Pago");

    if (shMetodos) {
      const ruleMetodoPago = SpreadsheetApp.newDataValidation()
        .requireValueInRange(shMetodos.getRange("J2:J"), true)
        .setAllowInvalid(false)
        .build();

      shAtajos.getRange(2, 3, filasAtajos.length, 1).setDataValidation(ruleMetodoPago);
    }
  }

  shAtajos.setFrozenRows(1);
  shAtajos.autoResizeColumns(1, 4);

  try {
    shAtajos.hideColumns(5);
  } catch (err) {}
}

function manejarEdicionAtajos(e) {
  if (!e || !e.range) return;

  const sheet = e.range.getSheet();
  if (sheet.getName() !== "Atajos") return;

  const row = e.range.getRow();
  const col = e.range.getColumn();

  if (row < 2) return;

  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const shAtajos = ss.getSheetByName("Atajos");
  const shPresupuesto = ss.getSheetByName("Presupuesto");
  const shMovimientos = ss.getSheetByName("Movimientos");

  if (!shAtajos || !shPresupuesto || !shMovimientos) {
    throw new Error("Faltan hojas requeridas: Atajos, Presupuesto o Movimientos.");
  }

  const filaPresupuesto = Number(shAtajos.getRange(row, 5).getValue());
  if (!filaPresupuesto) return;

  if (col === 2 || col === 3) {
    actualizarPresupuestoDesdeAtajo_(shAtajos, shPresupuesto, row, filaPresupuesto);
    return;
  }

  if (col === 4 && shAtajos.getRange(row, 4).getValue() === true) {
    actualizarPresupuestoDesdeAtajo_(shAtajos, shPresupuesto, row, filaPresupuesto);
    SpreadsheetApp.flush();

    registrarAtajoEnMovimientos_(shPresupuesto, shMovimientos, filaPresupuesto);

    shAtajos.getRange(row, 4).setValue(false);
    SpreadsheetApp.flush();
  }
}

function actualizarPresupuestoDesdeAtajo_(shAtajos, shPresupuesto, filaAtajo, filaPresupuesto) {
  const monto = shAtajos.getRange(filaAtajo, 2).getValue();
  const metodoPago = shAtajos.getRange(filaAtajo, 3).getValue();

  escribirValorPorHeaderAtajos_(shPresupuesto, filaPresupuesto, "Monto", monto);
  escribirValorPorHeaderAtajos_(shPresupuesto, filaPresupuesto, "Método de Pago", metodoPago);

  SpreadsheetApp.flush();
}

function registrarAtajoEnMovimientos_(shPresupuesto, shMovimientos, filaPresupuesto) {
  const ss = SpreadsheetApp.getActiveSpreadsheet();

  const presupuestoLastCol = shPresupuesto.getLastColumn();
  const presupuestoHeaders = shPresupuesto.getRange(1, 1, 1, presupuestoLastCol).getValues()[0];
  const presupuestoMap = crearHeaderMapAtajos_(presupuestoHeaders);

  const row = shPresupuesto.getRange(filaPresupuesto, 1, 1, presupuestoLastCol).getValues()[0];

  const concepto = leerCampoAtajos_(row, presupuestoMap, ["Concepto"]);
  const monto = leerCampoAtajos_(row, presupuestoMap, ["Monto"]);
  const metodoPago = leerCampoAtajos_(row, presupuestoMap, ["Método de Pago", "Metodo de Pago"]);
  const destino = leerCampoAtajos_(row, presupuestoMap, ["Destino"]);
  const destinoTC = leerCampoAtajos_(row, presupuestoMap, ["Destino_TC", "Destino TC"]);
  const destinoDeuda = leerCampoAtajos_(row, presupuestoMap, ["Destino_Deuda", "Destino Deuda"]);
  const moneda = leerCampoAtajos_(row, presupuestoMap, ["Moneda"]);
  const cop = leerCampoAtajos_(row, presupuestoMap, ["COP"]);
  const categoria = leerCampoAtajos_(row, presupuestoMap, ["Categoria", "Categoría"]);
  const naturaleza = leerCampoAtajos_(row, presupuestoMap, ["Naturaleza"]);
  const etiqueta = leerCampoAtajos_(row, presupuestoMap, ["Etiqueta"]);
  const meta = leerCampoAtajos_(row, presupuestoMap, ["Meta"]);

  if (!concepto) return;

  const hoy = new Date();
  hoy.setHours(0, 0, 0, 0);

  const timestamp = Utilities.formatDate(
    new Date(),
    ss.getSpreadsheetTimeZone(),
    "yyyyMMdd-HHmmss"
  );

  const idMovimiento = generarSiguienteIdMovimientoAtajos_(shMovimientos);
  const tipoMetodo = obtenerTipoMetodoAtajos_(metodoPago);
  const refPresupuesto = `ATAJO-F${filaPresupuesto}-${timestamp}`;

  const movimientosLastCol = shMovimientos.getLastColumn();
  const movimientosHeaders = shMovimientos.getRange(1, 1, 1, movimientosLastCol).getValues()[0];
  const movimientosMap = crearHeaderMapAtajos_(movimientosHeaders);

  const nuevaFila = new Array(movimientosLastCol).fill("");

  escribirCampoAtajos_(nuevaFila, movimientosMap, ["ID_Movimiento", "ID Movimiento"], idMovimiento);
  escribirCampoAtajos_(nuevaFila, movimientosMap, ["Fecha"], hoy);
  escribirCampoAtajos_(nuevaFila, movimientosMap, ["Concepto"], concepto);
  escribirCampoAtajos_(nuevaFila, movimientosMap, ["Monto"], monto);
  escribirCampoAtajos_(nuevaFila, movimientosMap, ["Moneda"], moneda);
  escribirCampoAtajos_(nuevaFila, movimientosMap, ["COP"], cop);
  escribirCampoAtajos_(nuevaFila, movimientosMap, ["Método de pago", "Método de Pago", "Metodo de pago", "Metodo de Pago"], metodoPago);
  escribirCampoAtajos_(nuevaFila, movimientosMap, ["Tipo método", "Tipo Método", "Tipo metodo", "Tipo Metodo"], tipoMetodo);
  escribirCampoAtajos_(nuevaFila, movimientosMap, ["Destino"], destino);
  escribirCampoAtajos_(nuevaFila, movimientosMap, ["Destino_TC", "Destino TC"], destinoTC);
  escribirCampoAtajos_(nuevaFila, movimientosMap, ["Destino_Deuda", "Destino Deuda"], destinoDeuda);
  escribirCampoAtajos_(nuevaFila, movimientosMap, ["Categoría", "Categoria"], categoria);
  escribirCampoAtajos_(nuevaFila, movimientosMap, ["Naturaleza"], naturaleza);
  escribirCampoAtajos_(nuevaFila, movimientosMap, ["Etiqueta"], etiqueta);
  escribirCampoAtajos_(nuevaFila, movimientosMap, ["Meta"], meta);
  escribirCampoAtajos_(nuevaFila, movimientosMap, ["Origen ejecución", "Origen ejecucion"], "Manual");
  escribirCampoAtajos_(nuevaFila, movimientosMap, ["Ref_Presupuesto", "Ref Presupuesto"], refPresupuesto);

  const targetRow = obtenerPrimeraFilaVaciaPorConceptoAtajos_(shMovimientos);

  shMovimientos
    .getRange(targetRow, 1, 1, movimientosLastCol)
    .setValues([nuevaFila]);

  aplicarValidacionEtiquetaMovimiento_(shMovimientos, targetRow);
  aplicarValidacionMetaMovimiento_(shMovimientos, targetRow);
}

function obtenerTipoMetodoAtajos_(metodoPago) {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const shMetodos = ss.getSheetByName("Métodos de Pago");

  if (!shMetodos || !metodoPago) return "";

  const lastRow = shMetodos.getLastRow();
  if (lastRow < 2) return "";

  const data = shMetodos.getRange(2, 2, lastRow - 1, 2).getValues();

  const encontrado = data.find(row =>
    String(row[0]).trim() === String(metodoPago).trim()
  );

  return encontrado ? encontrado[1] : "";
}

function generarSiguienteIdMovimientoAtajos_(shMovimientos) {
  const lastRow = shMovimientos.getLastRow();
  const lastCol = shMovimientos.getLastColumn();

  const headers = shMovimientos.getRange(1, 1, 1, lastCol).getValues()[0];
  const map = crearHeaderMapAtajos_(headers);

  const idCol = obtenerIndiceHeaderAtajos_(map, ["ID_Movimiento", "ID Movimiento"]);

  if (idCol === null || lastRow < 2) {
    return "MOV-0001";
  }

  const ids = shMovimientos
    .getRange(2, idCol + 1, lastRow - 1, 1)
    .getValues()
    .flat();

  const numeros = ids
    .map(id => {
      const match = String(id).match(/MOV-(\d+)/);
      return match ? Number(match[1]) : 0;
    })
    .filter(num => !isNaN(num));

  const maxId = numeros.length > 0 ? Math.max(...numeros) : 0;

  return `MOV-${String(maxId + 1).padStart(4, "0")}`;
}

function obtenerPrimeraFilaVaciaPorConceptoAtajos_(shMovimientos) {
  const lastCol = shMovimientos.getLastColumn();
  const headers = shMovimientos.getRange(1, 1, 1, lastCol).getValues()[0];
  const map = crearHeaderMapAtajos_(headers);

  const conceptoCol = obtenerIndiceHeaderAtajos_(map, ["Concepto"]);

  if (conceptoCol === null) {
    throw new Error("No se encontró la columna Concepto en Movimientos.");
  }

  const startRow = 2;
  const maxRows = shMovimientos.getMaxRows();
  const numRows = maxRows - 1;

  const conceptos = shMovimientos
    .getRange(startRow, conceptoCol + 1, numRows, 1)
    .getValues()
    .flat();

  for (let i = 0; i < conceptos.length; i++) {
    if (String(conceptos[i]).trim() === "") {
      return startRow + i;
    }
  }

  shMovimientos.insertRowsAfter(maxRows, 1);
  return maxRows + 1;
}

function crearTriggerAtajos() {
  eliminarTriggerAtajos();

  ScriptApp.newTrigger("manejarEdicionAtajos")
    .forSpreadsheet(SpreadsheetApp.getActiveSpreadsheet())
    .onEdit()
    .create();
}

function eliminarTriggerAtajos() {
  const triggers = ScriptApp.getProjectTriggers();

  triggers.forEach(trigger => {
    if (trigger.getHandlerFunction() === "manejarEdicionAtajos") {
      ScriptApp.deleteTrigger(trigger);
    }
  });
}

