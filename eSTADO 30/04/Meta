  asegurarValorEnRangoNombradoM10_(ss, "cat_recurrencia", "Mensual");
  asegurarValorEnRangoNombradoM10_(ss, "cat_monedas", "COP");
  asegurarValorEnRangoNombradoM10_(ss, "cat_origen_registro", "Generado desde meta");
  asegurarValorEnRangoNombradoM10_(ss, "cat_estado_ejecucion", "Pendiente");
}


function asegurarValorEnRangoNombradoM10_(ss, rangeName, value) {
  const namedRange = ss.getNamedRanges().find(item => item.getName() === rangeName);

  if (!namedRange) {
    Logger.log("No existe el rango con nombre: " + rangeName);
    return;
  }

  const range = namedRange.getRange();
  const sheet = range.getSheet();
  const values = range.getValues().flat().map(item => String(item || "").trim());

  if (values.includes(value)) return;

  const startRow = range.getRow();
  const col = range.getColumn();
  const numRows = range.getNumRows();

  for (let i = 0; i < numRows; i++) {
    if (String(values[i] || "").trim() === "") {
      sheet.getRange(startRow + i, col).setValue(value);
      return;
    }
  }

  const newRow = startRow + numRows;
  sheet.insertRowsBefore(newRow, 1);
  sheet.getRange(newRow, col).setValue(value);

  const newRange = sheet.getRange(startRow, col, numRows + 1, 1);
  ss.setNamedRange(rangeName, newRange);
}


function obtenerValorSeguroCatalogoM10_(ss, rangeName, fallback) {
  const range = ss.getRangeByName(rangeName);

  if (!range) return fallback;

  const values = range.getValues().flat().filter(String);

  if (values.includes(fallback)) return fallback;

  return values.length > 0 ? values[0] : fallback;
}


function limpiarValidacionesFilaPresupuestoM10_(sheet, rowNumber) {
  const lastCol = sheet.getLastColumn();
  sheet.getRange(rowNumber, 1, 1, lastCol).clearDataValidations();
}


function reaplicarValidacionesFilaPresupuestoM10_(sheet, rowNumber) {
  if (typeof repararValidacionesPresupuestoMovimientos === "function") {
    return;
  }

  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const metasActivas = typeof obtenerMetasActivasMetas_ === "function"
    ? obtenerMetasActivasMetas_(ss)
    : [];

  const metaCol = buscarColumnaPorEncabezadoMetas_(sheet, "Meta");

  if (metaCol && metasActivas.length > 0) {
    const rule = SpreadsheetApp.newDataValidation()
      .requireValueInList([...new Set(metasActivas.filter(String))], true)
      .setAllowInvalid(false)
      .build();

    sheet.getRange(rowNumber, metaCol).setDataValidation(rule);
  }
}


function obtenerPrimeraFilaVaciaPorHeaderM10_(sheet, headerName) {
  const col = buscarColumnaPorEncabezadoMetas_(sheet, headerName);

  if (!col) {
    throw new Error("No se encontró la columna " + headerName + " en " + sheet.getName());
  }

  const startRow = 2;
  const maxRows = sheet.getMaxRows();
  const values = sheet.getRange(startRow, col, maxRows - 1, 1).getValues().flat();

  for (let i = 0; i < values.length; i++) {
    if (String(values[i] || "").trim() === "") {
      return startRow + i;
    }
  }

  sheet.insertRowsAfter(maxRows, 1);
  return maxRows + 1;
}


function escribirValorPorHeaderM10_(sheet, rowNumber, headerName, value) {
  let col = buscarColumnaPorEncabezadoMetas_(sheet, headerName);

  if (!col && headerName === "Categoria") {
    col = buscarColumnaPorEncabezadoMetas_(sheet, "Categoría");
  }

  if (!col) {
    throw new Error("No se encontró la columna " + headerName + " en " + sheet.getName());
  }

  sheet.getRange(rowNumber, col).setValue(value);
}


function crearHeaderMapM10_(headers) {
  const map = {};

  headers.forEach((header, index) => {
    const key = normalizarTextoMetas_(header);

    if (key) {
      map[key] = index;
    }
  });

  return map;
}


function leerCampoM10_(row, map, posiblesNombres) {
  for (const nombre of posiblesNombres) {
    const key = normalizarTextoMetas_(nombre);

    if (Object.prototype.hasOwnProperty.call(map, key)) {
      return row[map[key]];
    }
  }

  return "";
}


