  const metasActivas = typeof obtenerMetasActivasMetas_ === "function"
    ? obtenerMetasActivasMetas_(ss)
    : [];

  if (metasActivas.length > 0) {
    const ruleMetas = SpreadsheetApp.newDataValidation()
      .requireValueInList([...new Set(metasActivas.filter(String))], true)
      .setAllowInvalid(false)
      .build();

    shRecordatorios.getRange(2, 4, numRows, 1).setDataValidation(ruleMetas);
  }
}


