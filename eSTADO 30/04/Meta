function eliminarFilasPorPrefijoHeaderM8_(sheet, headerName, prefix) {
  const col = buscarColumnaPorEncabezadoMetas_(sheet, headerName);

  if (!col) {
    Logger.log("No se encontró la columna " + headerName + " en " + sheet.getName());
    return;
  }

  const lastRow = sheet.getLastRow();

  if (lastRow < 2) return;

  const values = sheet.getRange(2, col, lastRow - 1, 1).getValues().flat();

  for (let i = values.length - 1; i >= 0; i--) {
    const value = String(values[i] || "").trim();

    if (value.indexOf(prefix) === 0) {
      sheet.deleteRow(i + 2);
    }
  }
}


function obtenerPrimeraFilaVaciaPorHeaderM8_(sheet, headerName) {
  const col = buscarColumnaPorEncabezadoMetas_(sheet, headerName);

  if (!col) {
    throw new Error("No se encontró la columna " + headerName + " en " + sheet.getName());
  }

  const startRow = 2;
  const maxRows = sheet.getMaxRows();
  const values = sheet.getRange(startRow, col, maxRows - 1, 1).getValues().flat();

  for (let i = 0; i < values.length; i++) {
    if (String(values[i] || "").trim() === "") {
      return startRow + i;
    }
  }

  sheet.insertRowsAfter(maxRows, 1);
  return maxRows + 1;
}


function buscarFilaPorValorHeaderM8_(sheet, headerName, valueToFind) {
  const col = buscarColumnaPorEncabezadoMetas_(sheet, headerName);

  if (!col) {
    throw new Error("No se encontró la columna " + headerName + " en " + sheet.getName());
  }

  const lastRow = sheet.getLastRow();

  if (lastRow < 2) return null;

  const values = sheet.getRange(2, col, lastRow - 1, 1).getValues().flat();

  for (let i = 0; i < values.length; i++) {
    if (String(values[i] || "").trim() === String(valueToFind).trim()) {
      return i + 2;
    }
  }

  return null;
}


function escribirValorPorHeaderM8_(sheet, rowNumber, headerName, value) {
  const col = buscarColumnaPorEncabezadoMetas_(sheet, headerName);

  if (!col) {
    throw new Error("No se encontró la columna " + headerName + " en " + sheet.getName());
  }

  sheet.getRange(rowNumber, col).setValue(value);
}


function leerValorPorHeaderM8_(sheet, rowNumber, headerName) {
  const col = buscarColumnaPorEncabezadoMetas_(sheet, headerName);

  if (!col) {
    throw new Error("No se encontró la columna " + headerName + " en " + sheet.getName());
