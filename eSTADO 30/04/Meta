    const nombreMeta = String(leerCampoM10_(row, metasMap, ["Nombre"]) || "").trim();
    const tipoMeta = String(leerCampoM10_(row, metasMap, ["Tipo meta"]) || "").trim();
    const categoriaRelacionada = String(leerCampoM10_(row, metasMap, ["Categoría relacionada", "Categoria relacionada"]) || "").trim();
    const cuentaReferencia = String(leerCampoM10_(row, metasMap, ["Cuenta referencia"]) || "").trim();
    const deudaRelacionada = String(leerCampoM10_(row, metasMap, ["Deuda relacionada"]) || "").trim();
    const aporteMensual = Number(leerCampoM10_(row, metasMap, ["Aporte mensual sugerido"]) || 0);
    const estado = String(leerCampoM10_(row, metasMap, ["Estado"]) || "").trim();

    if (!nombreMeta || estado !== "Activa" || !aporteMensual || aporteMensual <= 0) {
      omitidas++;
      return;
    }

    const concepto = "Aporte meta: " + nombreMeta;
    const filaPresupuestoExistente = buscarFilaPresupuestoPorMetaM10_(shPresupuesto, nombreMeta);

    const filaPresupuesto = filaPresupuestoExistente || obtenerPrimeraFilaVaciaPorHeaderM10_(shPresupuesto, "Concepto");

    const config = obtenerConfigPresupuestoMetaM10_({
      tipoMeta,
      categoriaRelacionada,
      cuentaReferencia,
      deudaRelacionada
    });

    limpiarValidacionesFilaPresupuestoM10_(shPresupuesto, filaPresupuesto);

    escribirValorPorHeaderM10_(shPresupuesto, filaPresupuesto, "Concepto", concepto);
    escribirValorPorHeaderM10_(shPresupuesto, filaPresupuesto, "Monto", aporteMensual);
    escribirValorPorHeaderM10_(shPresupuesto, filaPresupuesto, "Día de Pago", DIA_PAGO_META_DEFAULT);
    escribirValorPorHeaderM10_(shPresupuesto, filaPresupuesto, "Método de Pago", "");
    escribirValorPorHeaderM10_(shPresupuesto, filaPresupuesto, "Destino", config.destino);
    escribirValorPorHeaderM10_(shPresupuesto, filaPresupuesto, "Destino_TC", "");
    escribirValorPorHeaderM10_(shPresupuesto, filaPresupuesto, "Destino_Deuda", config.destinoDeuda);
    escribirValorPorHeaderM10_(shPresupuesto, filaPresupuesto, "Recurrencia", "Mensual");
    escribirValorPorHeaderM10_(shPresupuesto, filaPresupuesto, "Moneda", "COP");
    escribirValorPorHeaderM10_(shPresupuesto, filaPresupuesto, "COP", aporteMensual);
    escribirValorPorHeaderM10_(shPresupuesto, filaPresupuesto, "Tipo", "Recordatorio");
    escribirValorPorHeaderM10_(shPresupuesto, filaPresupuesto, "Categoria", config.categoria);
    escribirValorPorHeaderM10_(shPresupuesto, filaPresupuesto, "Naturaleza", config.naturaleza);
    escribirValorPorHeaderM10_(shPresupuesto, filaPresupuesto, "Etiqueta", config.etiqueta);
    escribirValorPorHeaderM10_(shPresupuesto, filaPresupuesto, "Meta", nombreMeta);
    escribirValorPorHeaderM10_(shPresupuesto, filaPresupuesto, "Activo", "Activo");
    escribirValorPorHeaderM10_(shPresupuesto, filaPresupuesto, "Versión presupuesto", obtenerValorSeguroCatalogoM10_(ss, "cat_version_presupuesto", "Actual"));
    escribirValorPorHeaderM10_(shPresupuesto, filaPresupuesto, "Origen del registro", "Generado desde meta");
    escribirValorPorHeaderM10_(shPresupuesto, filaPresupuesto, "Estado de ejecución", "Pendiente");

    reaplicarValidacionesFilaPresupuestoM10_(shPresupuesto, filaPresupuesto);

    if (filaPresupuestoExistente) {
      actualizadas++;
    } else {
      creadas++;
    }

    Logger.log("Meta procesada: " + nombreMeta + " → Presupuesto fila " + filaPresupuesto);
  });

  if (typeof repararValidacionesPresupuestoMovimientos === "function") {
    repararValidacionesPresupuestoMovimientos();
  }

  if (typeof setupMetas_M4A_ColumnasMeta === "function") {
    setupMetas_M4A_ColumnasMeta();
  }

  SpreadsheetApp.flush();

  Logger.log("M10 listo.");
  Logger.log("Presupuestos creados: " + creadas);
  Logger.log("Presupuestos actualizados: " + actualizadas);
  Logger.log("Metas omitidas: " + omitidas);
}


function obtenerConfigPresupuestoMetaM10_(data) {
  const tipo = String(data.tipoMeta || "").trim();
  const categoriaRelacionada = String(data.categoriaRelacionada || "").trim();
  const cuentaReferencia = String(data.cuentaReferencia || "").trim();
  const deudaRelacionada = String(data.deudaRelacionada || "").trim();

  if (tipo === "Consumo") {
    return {
      categoria: categoriaRelacionada || "Consumo Libre",
      naturaleza: "Egreso",
      etiqueta: "",
      destino: cuentaReferencia,
      destinoDeuda: ""
    };
  }

  if (tipo === "Deuda") {
    return {
      categoria: "Patrimonio",
      naturaleza: "Transferencia",
      etiqueta: "Abono extra a deuda",
      destino: cuentaReferencia,
      destinoDeuda: deudaRelacionada
    };
  }

  if (tipo === "Inversión") {
    return {
      categoria: "Patrimonio",
      naturaleza: "Transferencia",
      etiqueta: "",
      destino: cuentaReferencia,
      destinoDeuda: ""
    };
  }

  return {
    categoria: "Patrimonio",
    naturaleza: "Transferencia",
    etiqueta: "",
    destino: cuentaReferencia,
    destinoDeuda: ""
  };
}


function buscarFilaPresupuestoPorMetaM10_(sheet, nombreMeta) {
  const metaCol = buscarColumnaPorEncabezadoMetas_(sheet, "Meta");
  const origenCol = buscarColumnaPorEncabezadoMetas_(sheet, "Origen del registro");
  const conceptoCol = buscarColumnaPorEncabezadoMetas_(sheet, "Concepto");

  if (!metaCol || !conceptoCol) return null;

  const lastRow = sheet.getLastRow();

  if (lastRow < 2) return null;

  const metaValues = sheet.getRange(2, metaCol, lastRow - 1, 1).getValues().flat();
  const conceptoValues = sheet.getRange(2, conceptoCol, lastRow - 1, 1).getValues().flat();
  const origenValues = origenCol
    ? sheet.getRange(2, origenCol, lastRow - 1, 1).getValues().flat()
    : [];

  for (let i = 0; i < metaValues.length; i++) {
    const meta = String(metaValues[i] || "").trim();
    const concepto = String(conceptoValues[i] || "").trim();
    const origen = origenCol ? String(origenValues[i] || "").trim() : "";

    const esMismaMeta = meta === nombreMeta;
    const esConceptoMeta = concepto === "Aporte meta: " + nombreMeta;
    const esGeneradoDesdeMeta = origen === "Generado desde meta" || origen === "";

    if ((esMismaMeta || esConceptoMeta) && esGeneradoDesdeMeta) {
      return i + 2;
    }
  }

  return null;
}


function prepararCatalogosM10_(ss) {
  asegurarValorEnRangoNombradoM10_(ss, "cat_tipo_presupuesto", "Recordatorio");
