  sheet.getRange(nextRow, 1, 1, lastCol).setValues([row]);

  refrescarValidacionMetaEnFilaMovimiento_(sheet, nextRow);

  if (typeof aplicarValidacionEtiquetaEnFilaMovimiento_ === 'function') {
    try {
      aplicarValidacionEtiquetaEnFilaMovimiento_(nextRow);
    } catch (error) {
      Logger.log('No se pudo aplicar validación relacional de etiqueta en fila ' + nextRow + ': ' + error.message);
