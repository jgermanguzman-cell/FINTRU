  asegurarValorEnRangoNombradoM10_(ss, "cat_origen_registro", "Generado desde deuda");
  asegurarValorEnRangoNombradoM10_(ss, "cat_estado_ejecucion", "Pendiente");
}


function crearHeaderMapM11B_(headers) {
  const map = {};

  headers.forEach((header, index) => {
    const key = normalizarTextoMetas_(header);

    if (key) {
      map[key] = index;
    }
  });

  return map;
}


function leerCampoM11B_(row, map, posiblesNombres) {
  for (const nombre of posiblesNombres) {
    const key = normalizarTextoMetas_(nombre);

    if (Object.prototype.hasOwnProperty.call(map, key)) {
      return row[map[key]];
    }
  }

  return "";
}


