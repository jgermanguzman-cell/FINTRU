function obtenerFilaBloqueMetasDashboardData_(sheet) {
  const lastRow = Math.max(sheet.getLastRow(), 1);

  if (lastRow >= 1) {
    const values = sheet.getRange(1, 1, lastRow, 1).getValues().flat();

    for (let i = 0; i < values.length; i++) {
      if (String(values[i]).trim().toUpperCase() === "METAS Y BOLSILLOS") {
        return i + 1;
      }
    }
  }

  return lastRow + 3;
}


function obtenerColumnasMetasM6_(sheet, config) {
  const result = {};

  Object.keys(config).forEach(key => {
    const header = config[key];
    const col = buscarColumnaPorEncabezadoMetas_(sheet, header);

    if (!col) {
      throw new Error("No se encontró la columna '" + header + "' en la hoja " + sheet.getName());
    }

    result[key] = columnNumberToLetterMetas_(col);
  });

  return result;
}


function columnNumberToLetterMetas_(columnNumber) {
  let letter = "";
  let temp = columnNumber;

  while (temp > 0) {
    const remainder = (temp - 1) % 26;
    letter = String.fromCharCode(65 + remainder) + letter;
    temp = Math.floor((temp - remainder - 1) / 26);
  }

  return letter;
}


