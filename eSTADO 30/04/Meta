    const nombreDeuda = String(leerCampoM11B_(row, deudasMap, ["Nombre"]) || "").trim();
    const cuotaMensual = Number(leerCampoM11B_(row, deudasMap, ["Cuota mensual"]) || 0);
    const diaPago = Number(leerCampoM11B_(row, deudasMap, ["Día de pago", "Dia de pago"]) || 0);
    const cuentaPago = String(leerCampoM11B_(row, deudasMap, ["Cuenta de pago predeterminada"]) || "").trim();
    const estado = String(leerCampoM11B_(row, deudasMap, ["Estado"]) || "").trim();

    if (!nombreDeuda || !cuotaMensual || cuotaMensual <= 0 || !diaPago) {
      omitidas++;
      return;
    }

    if (!["Activa", "Activo", "Vigente", ""].includes(estado)) {
      omitidas++;
      return;
    }

    const filaPresupuestoExistente = buscarFilaPresupuestoPorDeudaM11B_(shPresupuesto, nombreDeuda);
    const filaPresupuesto = filaPresupuestoExistente || obtenerPrimeraFilaVaciaPorHeaderM10_(shPresupuesto, "Concepto");

    limpiarValidacionesFilaPresupuestoM10_(shPresupuesto, filaPresupuesto);

    escribirValorPorHeaderM10_(shPresupuesto, filaPresupuesto, "Concepto", "Pago deuda: " + nombreDeuda);
    escribirValorPorHeaderM10_(shPresupuesto, filaPresupuesto, "Monto", cuotaMensual);
    escribirValorPorHeaderM10_(shPresupuesto, filaPresupuesto, "Día de Pago", diaPago);
    escribirValorPorHeaderM10_(shPresupuesto, filaPresupuesto, "Método de Pago", cuentaPago);
    escribirValorPorHeaderM10_(shPresupuesto, filaPresupuesto, "Destino", cuentaPago);
    escribirValorPorHeaderM10_(shPresupuesto, filaPresupuesto, "Destino_TC", "");
    escribirValorPorHeaderM10_(shPresupuesto, filaPresupuesto, "Destino_Deuda", nombreDeuda);
    escribirValorPorHeaderM10_(shPresupuesto, filaPresupuesto, "Recurrencia", "Mensual");
    escribirValorPorHeaderM10_(shPresupuesto, filaPresupuesto, "Moneda", "COP");
    escribirValorPorHeaderM10_(shPresupuesto, filaPresupuesto, "COP", cuotaMensual);
    escribirValorPorHeaderM10_(shPresupuesto, filaPresupuesto, "Tipo", "Recordatorio");
    escribirValorPorHeaderM10_(shPresupuesto, filaPresupuesto, "Categoria", "N/A");
    escribirValorPorHeaderM10_(shPresupuesto, filaPresupuesto, "Naturaleza", "Transferencia");
    escribirValorPorHeaderM10_(shPresupuesto, filaPresupuesto, "Etiqueta", "Pago de deuda");
    escribirValorPorHeaderM10_(shPresupuesto, filaPresupuesto, "Meta", "");
    escribirValorPorHeaderM10_(shPresupuesto, filaPresupuesto, "Activo", "Activo");
    escribirValorPorHeaderM10_(shPresupuesto, filaPresupuesto, "Versión presupuesto", obtenerValorSeguroCatalogoM10_(ss, "cat_version_presupuesto", "Actual"));
    escribirValorPorHeaderM10_(shPresupuesto, filaPresupuesto, "Origen del registro", "Generado desde deuda");
    escribirValorPorHeaderM10_(shPresupuesto, filaPresupuesto, "Estado de ejecución", "Pendiente");

    if (filaPresupuestoExistente) {
      actualizadas++;
    } else {
      creadas++;
    }

    Logger.log("Deuda procesada: " + nombreDeuda + " → Presupuesto fila " + filaPresupuesto);
  });

  if (typeof repararValidacionesPresupuestoMovimientos === "function") {
    repararValidacionesPresupuestoMovimientos();
  }

  if (typeof refrescarMetas_M11_Recordatorios === "function") {
    refrescarMetas_M11_Recordatorios();
  }

  SpreadsheetApp.flush();

  Logger.log("M11B listo.");
  Logger.log("Recordatorios de deuda creados: " + creadas);
  Logger.log("Recordatorios de deuda actualizados: " + actualizadas);
  Logger.log("Deudas omitidas: " + omitidas);
}


function buscarFilaPresupuestoPorDeudaM11B_(sheet, nombreDeuda) {
  const conceptoCol = buscarColumnaPorEncabezadoMetas_(sheet, "Concepto");
  const destinoDeudaCol = buscarColumnaPorEncabezadoMetas_(sheet, "Destino_Deuda");
  const etiquetaCol = buscarColumnaPorEncabezadoMetas_(sheet, "Etiqueta");

  if (!conceptoCol) return null;

  const lastRow = sheet.getLastRow();

  if (lastRow < 2) return null;

  const data = sheet.getRange(2, 1, lastRow - 1, sheet.getLastColumn()).getValues();

  const nombreNormalizado = normalizarTextoMetas_(nombreDeuda);

  for (let i = 0; i < data.length; i++) {
    const row = data[i];

    const concepto = String(row[conceptoCol - 1] || "").trim();
    const destinoDeuda = destinoDeudaCol ? String(row[destinoDeudaCol - 1] || "").trim() : "";
    const etiqueta = etiquetaCol ? String(row[etiquetaCol - 1] || "").trim() : "";

    const conceptoNormalizado = normalizarTextoMetas_(concepto);
    const destinoNormalizado = normalizarTextoMetas_(destinoDeuda);

    const coincidePorDestino = destinoNormalizado === nombreNormalizado && etiqueta === "Pago de deuda";
    const coincidePorConcepto = conceptoNormalizado === normalizarTextoMetas_("Pago deuda: " + nombreDeuda) ||
      conceptoNormalizado === normalizarTextoMetas_("Pago deuda " + nombreDeuda) ||
      conceptoNormalizado.includes(nombreNormalizado) && conceptoNormalizado.includes("pago deuda");

    if (coincidePorDestino || coincidePorConcepto) {
      return i + 2;
    }
  }

  return null;
}


