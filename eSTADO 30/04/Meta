  const startRow = obtenerFilaBloqueRecordatoriosDashboardData_(shDashboardData);

  Logger.log("Bloque RECORDATORIOS encontrado en fila: " + startRow);
  Logger.log("Periodo actual: " + shDashboardData.getRange(startRow + 1, 2).getValue());
  Logger.log("Pendientes: " + shDashboardData.getRange(startRow + 2, 2).getValue());
  Logger.log("Pagados: " + shDashboardData.getRange(startRow + 3, 2).getValue());
  Logger.log("Total pendiente: " + shDashboardData.getRange(startRow + 4, 2).getValue());
}
