function refrescarMetas_M11_Recordatorios() {
  const ss = SpreadsheetApp.getActiveSpreadsheet();

  const shPresupuesto = ss.getSheetByName("Presupuesto");
  const shMovimientos = ss.getSheetByName("Movimientos");

  if (!shPresupuesto || !shMovimientos) {
    throw new Error("Faltan hojas requeridas: Presupuesto o Movimientos.");
  }

  let shRecordatorios = ss.getSheetByName("Recordatorios");

  if (!shRecordatorios) {
    shRecordatorios = ss.insertSheet("Recordatorios");
  }

  try {
    shRecordatorios.showColumns(1, shRecordatorios.getMaxColumns());
  } catch (err) {}

  shRecordatorios.clearContents();
  shRecordatorios.getDataRange().clearDataValidations();

  const headers = [
    "Concepto",
    "Monto",
    "Método de Pago",
    "Meta",
    "Fecha sugerida",
    "Periodo",
    "Registrar como pagado",
    "Fila Presupuesto",
    "Ref del mes",
    "Estado"
  ];

  shRecordatorios.getRange(1, 1, 1, headers.length).setValues([headers]);

  const hoy = new Date();
  hoy.setHours(0, 0, 0, 0);

  const anio = hoy.getFullYear();
  const mesIndex = hoy.getMonth();
  const periodo = obtenerPeriodoM11_(hoy);
  const ultimoDiaMes = new Date(anio, mesIndex + 1, 0).getDate();

  const presupuestoLastRow = shPresupuesto.getLastRow();
  const presupuestoLastCol = shPresupuesto.getLastColumn();

  if (presupuestoLastRow < 2) {
    aplicarFormatoM11_Recordatorios_(shRecordatorios);
    return;
  }

  const presupuestoHeaders = shPresupuesto.getRange(1, 1, 1, presupuestoLastCol).getValues()[0];
  const presupuestoMap = crearHeaderMapM11_(presupuestoHeaders);
  const presupuestoData = shPresupuesto.getRange(2, 1, presupuestoLastRow - 1, presupuestoLastCol).getValues();

  const refsRegistradas = obtenerRefsRegistradasM11_(shMovimientos);

  const filas = [];

  presupuestoData.forEach((row, index) => {
    const filaPresupuesto = index + 2;

    const concepto = String(leerCampoM11_(row, presupuestoMap, ["Concepto"]) || "").trim();
    const monto = leerCampoM11_(row, presupuestoMap, ["Monto"]);
    const metodoPago = leerCampoM11_(row, presupuestoMap, ["Método de Pago", "Metodo de Pago"]);
    const meta = leerCampoM11_(row, presupuestoMap, ["Meta"]);
    const diaPagoRaw = leerCampoM11_(row, presupuestoMap, ["Día de Pago", "Dia de Pago"]);
    const tipo = String(leerCampoM11_(row, presupuestoMap, ["Tipo"]) || "").trim();
    const activo = String(leerCampoM11_(row, presupuestoMap, ["Activo"]) || "").trim();
    const recurrencia = String(leerCampoM11_(row, presupuestoMap, ["Recurrencia"]) || "").trim();

    if (!concepto) return;
    if (tipo !== "Recordatorio") return;
    if (activo !== "Activo") return;
    if (recurrencia !== "Mensual") return;

    let diaPago = "";

    if (diaPagoRaw instanceof Date) {
      diaPago = diaPagoRaw.getDate();
    } else {
      diaPago = Number(diaPagoRaw);
    }

    if (!diaPago) return;

    const diaEjecucion = Math.min(diaPago, ultimoDiaMes);

    const fechaSugerida = new Date(anio, mesIndex, diaEjecucion);
    fechaSugerida.setHours(0, 0, 0, 0);

    const refMes = `RECORDATORIO-F${filaPresupuesto}-${periodo}`;
    const yaRegistrado = refsRegistradas.includes(refMes);

    filas.push([
      concepto,
      monto,
      metodoPago,
      meta,
      fechaSugerida,
      periodo,
      false,
      filaPresupuesto,
      refMes,
      yaRegistrado ? "Registrado" : "Pendiente"
    ]);
  });

  if (filas.length > 0) {
   shRecordatorios.getRange(2, 1, filas.length, headers.length).setValues(filas);

    filas.forEach((fila, index) => {
    const rowNumber = index + 2;
    const estado = String(fila[9] || "").trim();
    const cell = shRecordatorios.getRange(rowNumber, 7);

  if (estado === "Registrado") {
    cell.clearDataValidations();
    cell.setValue("Pagado ✅");
    cell.setHorizontalAlignment("center");
    cell.setFontWeight("bold");
  } else {
    cell.insertCheckboxes();
  }
});

    aplicarValidacionesM11_Recordatorios_(ss, shRecordatorios, filas.length);
  }

  aplicarFormatoM11_Recordatorios_(shRecordatorios);

  try {
    shRecordatorios.hideColumns(8, 2);
  } catch (err) {}

  SpreadsheetApp.flush();

  Logger.log("Recordatorios generados: " + filas.length);
}


function obtenerRefsRegistradasM11_(shMovimientos) {
  const refCol = buscarColumnaPorEncabezadoMetas_(shMovimientos, "Ref_Presupuesto");

  if (!refCol) return [];

  const lastRow = shMovimientos.getLastRow();

  if (lastRow < 2) return [];

  return shMovimientos
    .getRange(2, refCol, lastRow - 1, 1)
