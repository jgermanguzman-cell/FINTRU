  aplicarFormatoMetas_(sheet);

  SpreadsheetApp.flush();
}


function aplicarValidacionRangoNombradoMetas_(ss, sheet, columnLetter, startRow, maxRows, namedRangeName) {
  const namedRange = ss.getNamedRanges().find(item => item.getName() === namedRangeName);

  if (!namedRange) {
    Logger.log('No existe el rango con nombre: ' + namedRangeName);
    return;
  }

  const rule = SpreadsheetApp.newDataValidation()
    .requireValueInRange(namedRange.getRange(), true)
    .setAllowInvalid(false)
    .build();

  const column = columnLetterToNumberMetas_(columnLetter);
  sheet.getRange(startRow, column, maxRows, 1).setDataValidation(rule);
}


function aplicarValidacionListaMetas_(sheet, columnLetter, startRow, maxRows, values) {
  const column = columnLetterToNumberMetas_(columnLetter);

  if (!values || values.length === 0) {
    Logger.log('No hay valores para validar en columna ' + columnLetter);
    sheet.getRange(startRow, column, maxRows, 1).clearDataValidations();
    return;
  }

  const uniqueValues = [...new Set(values.filter(String))];

  const rule = SpreadsheetApp.newDataValidation()
    .requireValueInList(uniqueValues, true)
    .setAllowInvalid(false)
    .build();

  sheet.getRange(startRow, column, maxRows, 1).setDataValidation(rule);
}


function obtenerCuentasActivasMetas_(ss) {
  const sheet = ss.getSheetByName('Cuentas');

  if (!sheet) {
    Logger.log('No existe la hoja Cuentas');
    return [];
  }

  const lastRow = sheet.getLastRow();

  if (lastRow < 2) return [];

  const data = sheet.getRange(2, 2, lastRow - 1, 9).getValues();
  // Dentro de este rango:
  // B = Nombre → índice 0
  // J = Estado → índice 8

  return data
    .filter(row => {
      const nombre = String(row[0] || '').trim();
      const estado = String(row[8] || '').trim().toLowerCase();

      if (!nombre) return false;

      return estado === '' ||
        estado === 'activa' ||
        estado === 'activo' ||
        estado === 'vigente';
    })
    .map(row => String(row[0]).trim());
}


