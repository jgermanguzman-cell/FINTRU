function manejarEdicionRecordatorios(e) {
  if (!e || !e.range) return;

  const sheet = e.range.getSheet();
  if (sheet.getName() !== "Recordatorios") return;

  const row = e.range.getRow();
  const col = e.range.getColumn();

  if (row < 2) return;

  const registrarCol = buscarColumnaPorEncabezadoMetas_(sheet, "Registrar como pagado");
  if (!registrarCol || col !== registrarCol) return;

  const marcado = sheet.getRange(row, registrarCol).getValue();
  if (marcado !== true) return;

  registrarRecordatorioComoMovimiento_(row);
}


function registrarRecordatorioComoMovimiento_(filaRecordatorio) {
  const ss = SpreadsheetApp.getActiveSpreadsheet();

  const shRecordatorios = ss.getSheetByName("Recordatorios");
  const shPresupuesto = ss.getSheetByName("Presupuesto");
  const shMovimientos = ss.getSheetByName("Movimientos");

  if (!shRecordatorios || !shPresupuesto || !shMovimientos) {
    throw new Error("Faltan hojas requeridas: Recordatorios, Presupuesto o Movimientos.");
  }

  const filaPresupuesto = Number(leerValorPorHeaderM12_(shRecordatorios, filaRecordatorio, "Fila Presupuesto"));
  const refMes = String(leerValorPorHeaderM12_(shRecordatorios, filaRecordatorio, "Ref del mes") || "").trim();

  if (!filaPresupuesto || !refMes) {
    escribirValorPorHeaderM12_(shRecordatorios, filaRecordatorio, "Estado", "Error");
    escribirValorPorHeaderM12_(shRecordatorios, filaRecordatorio, "Registrar como pagado", false);
    throw new Error("Falta Fila Presupuesto o Ref del mes en Recordatorios.");
  }

  if (existeRefMovimientoM12_(shMovimientos, refMes)) {
    marcarRecordatorioComoPagadoUX_M12_(shRecordatorios, filaRecordatorio);
    return;
  }

  const movimiento = construirMovimientoDesdeFilaPresupuestoM12_(shPresupuesto, filaPresupuesto, refMes);

  crearMovimientoDesdeObjetoMetas_(movimiento);

  escribirValorPorHeaderM12_(shRecordatorios, filaRecordatorio, "Estado", "Registrado");
  escribirValorPorHeaderM12_(shRecordatorios, filaRecordatorio, "Registrar como pagado", false);

  actualizarEstadoEjecucionPresupuestoM12_(shPresupuesto, filaPresupuesto, "Registrado");

  if (typeof setupMetas_M5_Calculos === "function") {
    setupMetas_M5_Calculos();
  }

  if (typeof setupMetas_M6_DashboardData === "function") {
    setupMetas_M6_DashboardData();
  }

  if (typeof setupMetas_M7_DashboardVisual === "function") {
    setupMetas_M7_DashboardVisual();
  }

  SpreadsheetApp.flush();
}


function construirMovimientoDesdeFilaPresupuestoM12_(shPresupuesto, filaPresupuesto, refMes) {
  return {
    fecha: new Date(),
    concepto: leerValorPorHeaderM12_(shPresupuesto, filaPresupuesto, "Concepto"),
    monto: leerValorPorHeaderM12_(shPresupuesto, filaPresupuesto, "Monto"),
    moneda: leerValorPorHeaderM12_(shPresupuesto, filaPresupuesto, "Moneda") || "COP",
    cop: leerValorPorHeaderM12_(shPresupuesto, filaPresupuesto, "COP") || leerValorPorHeaderM12_(shPresupuesto, filaPresupuesto, "Monto"),
    metodoPago: leerValorPorHeaderM12_(shPresupuesto, filaPresupuesto, "Método de Pago"),
    tipoMetodo: obtenerTipoMetodoRecordatorioM12_(leerValorPorHeaderM12_(shPresupuesto, filaPresupuesto, "Método de Pago")),
    destino: leerValorPorHeaderM12_(shPresupuesto, filaPresupuesto, "Destino"),
    destinoTC: leerValorPorHeaderM12_(shPresupuesto, filaPresupuesto, "Destino_TC"),
    destinoDeuda: leerValorPorHeaderM12_(shPresupuesto, filaPresupuesto, "Destino_Deuda"),
    categoria: leerValorPorHeaderM12_(shPresupuesto, filaPresupuesto, "Categoria") || leerValorPorHeaderM12_(shPresupuesto, filaPresupuesto, "Categoría"),
    naturaleza: leerValorPorHeaderM12_(shPresupuesto, filaPresupuesto, "Naturaleza"),
    etiqueta: leerValorPorHeaderM12_(shPresupuesto, filaPresupuesto, "Etiqueta"),
    meta: leerValorPorHeaderM12_(shPresupuesto, filaPresupuesto, "Meta"),
    origenEjecucion: "Recordatorio confirmado",
    refPresupuesto: refMes
  };
}


function existeRefMovimientoM12_(shMovimientos, refMes) {
  const refCol = buscarColumnaPorEncabezadoMetas_(shMovimientos, "Ref_Presupuesto");

  if (!refCol) return false;

  const lastRow = shMovimientos.getLastRow();
  if (lastRow < 2) return false;

  const refs = shMovimientos
    .getRange(2, refCol, lastRow - 1, 1)
    .getValues()
    .flat()
    .map(value => String(value || "").trim());

  return refs.includes(refMes);
}


function actualizarEstadoEjecucionPresupuestoM12_(shPresupuesto, filaPresupuesto, estado) {
  const estadoCol = buscarColumnaPorEncabezadoMetas_(shPresupuesto, "Estado de ejecución");

  if (!estadoCol) return;

  const cell = shPresupuesto.getRange(filaPresupuesto, estadoCol);

  try {
    cell.clearDataValidations();
    cell.setValue(estado);
  } catch (err) {
    Logger.log("No se pudo actualizar Estado de ejecución: " + err.message);
  }
}


function obtenerTipoMetodoRecordatorioM12_(metodoPago) {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const shMetodos = ss.getSheetByName("Métodos de Pago");

  if (!shMetodos || !metodoPago) return "";

  const lastRow = shMetodos.getLastRow();
  if (lastRow < 2) return "";

  const data = shMetodos.getRange(2, 2, lastRow - 1, 2).getValues();

  const encontrado = data.find(row =>
    String(row[0]).trim() === String(metodoPago).trim()
  );

  return encontrado ? encontrado[1] : "";
}


function leerValorPorHeaderM12_(sheet, rowNumber, headerName) {
  let col = buscarColumnaPorEncabezadoMetas_(sheet, headerName);

  if (!col && headerName === "Categoria") {
    col = buscarColumnaPorEncabezadoMetas_(sheet, "Categoría");
  }

  if (!col) return "";

  return sheet.getRange(rowNumber, col).getValue();
}


function escribirValorPorHeaderM12_(sheet, rowNumber, headerName, value) {
  const col = buscarColumnaPorEncabezadoMetas_(sheet, headerName);

  if (!col) {
    throw new Error("No se encontró la columna " + headerName + " en " + sheet.getName());
  }

  const cell = sheet.getRange(rowNumber, col);

  try {
    cell.clearDataValidations();
  } catch (err) {}

  cell.setValue(value);
}


