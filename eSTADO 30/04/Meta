function setupMetas_M14B_DashboardVisualRecordatorios() {
  const ss = SpreadsheetApp.getActiveSpreadsheet();

  const shDashboard = ss.getSheetByName("Dashboard");
  const shDashboardData = ss.getSheetByName("Dashboard_Data");

  if (!shDashboard || !shDashboardData) {
    throw new Error("Faltan hojas requeridas: Dashboard o Dashboard_Data.");
  }

  const dataStartRow = obtenerFilaBloqueRecordatoriosDashboardData_(shDashboardData);
  const startRow = obtenerFilaBloqueRecordatoriosDashboardVisual_(shDashboard);

  const rows = [
    ["Recordatorios del mes", "", "", ""],
    ["Pendientes", `=Dashboard_Data!B${dataStartRow + 2}`, "Pagados", `=Dashboard_Data!B${dataStartRow + 3}`],
    ["Total pendiente", `=Dashboard_Data!B${dataStartRow + 4}`, "Total pagado", `=Dashboard_Data!B${dataStartRow + 5}`],
    ["Metas pendientes", `=Dashboard_Data!B${dataStartRow + 6}`, "Deudas pendientes", `=Dashboard_Data!B${dataStartRow + 7}`]
  ];

  shDashboard.getRange(startRow, 1, rows.length, 4).setValues(rows);

  shDashboard.getRange(startRow, 1, 1, 4)
    .merge()
    .setFontWeight("bold")
    .setFontSize(14)
    .setBackground("#f3f4f6");

  shDashboard.getRange(startRow + 1, 1, 3, 4)
    .setVerticalAlignment("middle")
    .setBorder(true, true, true, true, true, true);

  shDashboard.getRange(startRow + 1, 1, 3, 1).setFontWeight("bold");
  shDashboard.getRange(startRow + 1, 3, 3, 1).setFontWeight("bold");

  shDashboard.getRange(startRow + 2, 2, 1, 1).setNumberFormat("$#,##0");
  shDashboard.getRange(startRow + 2, 4, 1, 1).setNumberFormat("$#,##0");

  shDashboard.setColumnWidth(1, 180);
  shDashboard.setColumnWidth(2, 140);
  shDashboard.setColumnWidth(3, 180);
  shDashboard.setColumnWidth(4, 140);

  SpreadsheetApp.flush();

  Logger.log("Bloque Recordatorios del mes creado/actualizado en Dashboard desde fila " + startRow);
}


function obtenerFilaBloqueRecordatoriosDashboardVisual_(sheet) {
  const lastRow = Math.max(sheet.getLastRow(), 1);

  const values = sheet.getRange(1, 1, lastRow, 1).getValues().flat();

  for (let i = 0; i < values.length; i++) {
    if (String(values[i]).trim().toLowerCase() === "recordatorios del mes") {
      return i + 1;
    }
  }

  return lastRow + 3;
}


function verificarMetas_M14B_DashboardVisualRecordatorios() {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const shDashboard = ss.getSheetByName("Dashboard");

  if (!shDashboard) {
    Logger.log("Dashboard NO existe.");
    return;
  }

  const startRow = obtenerFilaBloqueRecordatoriosDashboardVisual_(shDashboard);

  Logger.log("Bloque Recordatorios del mes encontrado en fila: " + startRow);
  Logger.log("Título: " + shDashboard.getRange(startRow, 1).getValue());
  Logger.log("Pendientes: " + shDashboard.getRange(startRow + 1, 2).getValue());
  Logger.log("Pagados: " + shDashboard.getRange(startRow + 1, 4).getValue());
  Logger.log("Total pendiente: " + shDashboard.getRange(startRow + 2, 2).getValue());
}
