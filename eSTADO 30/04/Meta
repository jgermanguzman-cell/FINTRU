function diagnosticarHeadersMetas_(ss, sheetName, expectedHeaders) {
  const sheet = ss.getSheetByName(sheetName);

  if (!sheet) {
    Logger.log(sheetName + ': NO EXISTE');
    return;
  }

  const headerMap = obtenerMapaHeadersMetas_(sheet);

  Logger.log('--- ' + sheetName + ' ---');

  expectedHeaders.forEach(header => {
    const col = headerMap[normalizarTextoMetas_(header)];

    if (col) {
      Logger.log(header + ': OK → columna ' + col);
    } else {
      Logger.log(header + ': FALTA');
    }
  });
}


function obtenerMapaHeadersMetas_(sheet) {
  const lastCol = sheet.getLastColumn();

  if (lastCol < 1) return {};

  const headers = sheet.getRange(1, 1, 1, lastCol).getValues()[0];
  const map = {};

  headers.forEach((header, index) => {
    const key = normalizarTextoMetas_(header);

    if (key) {
      map[key] = index + 1;
    }
  });

  return map;
}


function obtenerValorPorHeaderMetas_(sheet, rowNumber, headerName) {
  const headerMap = obtenerMapaHeadersMetas_(sheet);
  const col = headerMap[normalizarTextoMetas_(headerName)];

  if (!col) return '';

  return sheet.getRange(rowNumber, col).getValue();
}


function escribirValorPorHeaderMetas_(sheet, rowNumber, headerName, value) {
  const headerMap = obtenerMapaHeadersMetas_(sheet);
  const col = headerMap[normalizarTextoMetas_(headerName)];

  if (!col) {
    throw new Error('No existe la columna "' + headerName + '" en la hoja ' + sheet.getName());
  }

  sheet.getRange(rowNumber, col).setValue(value);
}


function crearMovimientoDesdeObjetoMetas_(movimiento) {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const sheet = ss.getSheetByName('Movimientos');

  if (!sheet) {
    throw new Error('No existe la hoja Movimientos');
  }

  const headerMap = obtenerMapaHeadersMetas_(sheet);
  const lastCol = sheet.getLastColumn();

  const nextRow = obtenerPrimeraFilaVaciaMovimientoMetas_(sheet);

  const metaCol = buscarColumnaPorEncabezadoMetas_(sheet, 'Meta');

  if (metaCol) {
    sheet.getRange(nextRow, metaCol).clearDataValidations();
  }

  const row = new Array(lastCol).fill('');

  setRowValueByHeaderMetas_(row, headerMap, 'ID_Movimiento', movimiento.idMovimiento || generarIdMovimientoMetas_());
  setRowValueByHeaderMetas_(row, headerMap, 'Fecha', movimiento.fecha || new Date());
  setRowValueByHeaderMetas_(row, headerMap, 'Concepto', movimiento.concepto || '');
  setRowValueByHeaderMetas_(row, headerMap, 'Monto', movimiento.monto || '');
  setRowValueByHeaderMetas_(row, headerMap, 'Moneda', movimiento.moneda || 'COP');
  setRowValueByHeaderMetas_(row, headerMap, 'COP', movimiento.cop || movimiento.monto || '');
  setRowValueByHeaderMetas_(row, headerMap, 'Método de pago', movimiento.metodoPago || '');
  setRowValueByHeaderMetas_(row, headerMap, 'Tipo método', movimiento.tipoMetodo || '');
  setRowValueByHeaderMetas_(row, headerMap, 'Destino', movimiento.destino || '');
  setRowValueByHeaderMetas_(row, headerMap, 'Destino_TC', movimiento.destinoTC || '');
  setRowValueByHeaderMetas_(row, headerMap, 'Destino_Deuda', movimiento.destinoDeuda || '');
  setRowValueByHeaderMetas_(row, headerMap, 'Categoría', movimiento.categoria || '');
  setRowValueByHeaderMetas_(row, headerMap, 'Naturaleza', movimiento.naturaleza || '');
  setRowValueByHeaderMetas_(row, headerMap, 'Etiqueta', movimiento.etiqueta || '');
