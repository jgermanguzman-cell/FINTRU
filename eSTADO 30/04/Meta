function verificarRecordatoriosSiguienteMes() {
  const ss = SpreadsheetApp.getActiveSpreadsheet();

  const shPresupuesto = ss.getSheetByName("Presupuesto");
  const shMovimientos = ss.getSheetByName("Movimientos");

  if (!shPresupuesto || !shMovimientos) {
    throw new Error("Faltan hojas requeridas: Presupuesto o Movimientos.");
  }

  const hoy = new Date();
  hoy.setHours(0, 0, 0, 0);

  const siguienteMes = new Date(hoy.getFullYear(), hoy.getMonth() + 1, 1);
  siguienteMes.setHours(0, 0, 0, 0);

  const periodoActual = obtenerPeriodoM11_(hoy);
  const periodoSiguiente = obtenerPeriodoM11_(siguienteMes);

  const refsRegistradas = obtenerRefsRegistradasM11_(shMovimientos);

  const lastRow = shPresupuesto.getLastRow();
  const lastCol = shPresupuesto.getLastColumn();

  if (lastRow < 2) {
    Logger.log("No hay filas en Presupuesto.");
    return;
  }

  const headers = shPresupuesto.getRange(1, 1, 1, lastCol).getValues()[0];
  const map = crearHeaderMapM11_(headers);
  const data = shPresupuesto.getRange(2, 1, lastRow - 1, lastCol).getValues();

  Logger.log("Periodo actual: " + periodoActual);
  Logger.log("Periodo siguiente: " + periodoSiguiente);
  Logger.log("===== VERIFICACIÓN SIGUIENTE MES =====");

  data.forEach((row, index) => {
    const filaPresupuesto = index + 2;

    const concepto = String(leerCampoM11_(row, map, ["Concepto"]) || "").trim();
    const tipo = String(leerCampoM11_(row, map, ["Tipo"]) || "").trim();
    const activo = String(leerCampoM11_(row, map, ["Activo"]) || "").trim();
    const recurrencia = String(leerCampoM11_(row, map, ["Recurrencia"]) || "").trim();

    if (!concepto) return;
    if (tipo !== "Recordatorio") return;
    if (activo !== "Activo") return;
    if (recurrencia !== "Mensual") return;

    const refActual = `RECORDATORIO-F${filaPresupuesto}-${periodoActual}`;
    const refSiguiente = `RECORDATORIO-F${filaPresupuesto}-${periodoSiguiente}`;

    const estadoActual = refsRegistradas.includes(refActual) ? "Registrado" : "Pendiente";
    const estadoSiguiente = refsRegistradas.includes(refSiguiente) ? "Registrado" : "Pendiente";

    Logger.log(concepto);
    Logger.log("Este mes: " + refActual + " → " + estadoActual);
    Logger.log("Siguiente mes: " + refSiguiente + " → " + estadoSiguiente);
    Logger.log("----------------------");
  });
}
