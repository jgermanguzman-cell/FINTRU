function setupMetas_M1_Catalogos() {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const sheet = ss.getSheetByName('Catálogos') || ss.getSheetByName('Catalogos') || ss.insertSheet('Catálogos');

  const catalogs = [
    {
      rangeName: 'cat_tipo_meta',
      header: 'Tipo meta',
      values: ['Consumo', 'Patrimonio', 'Deuda', 'Ahorro', 'Inversión', 'Libertad financiera']
    },
    {
      rangeName: 'cat_prioridad_meta',
      header: 'Prioridad meta',
      values: ['Alta', 'Media', 'Baja']
    },
    {
      rangeName: 'cat_tipo_movimiento_meta',
      header: 'Tipo movimiento meta',
      values: ['Asignación virtual', 'Retiro virtual', 'Ajuste manual']
    },
    {
      rangeName: 'cat_estado_meta',
      header: 'Estado meta',
      values: ['Activa', 'Pausada', 'Completada', 'Cancelada']
    }
  ];

  catalogs.forEach(catalog => {
    upsertCatalogoMetas_(ss, sheet, catalog.rangeName, catalog.header, catalog.values);
  });

  SpreadsheetApp.flush();
}


function upsertCatalogoMetas_(ss, defaultSheet, rangeName, header, values) {
  const existingNamedRange = ss.getNamedRanges().find(namedRange => namedRange.getName() === rangeName);

  let sheet = defaultSheet;
  let startRow = 2;
  let col = null;

  if (existingNamedRange) {
    const existingRange = existingNamedRange.getRange();

    sheet = existingRange.getSheet();
    startRow = existingRange.getRow();
    col = existingRange.getColumn();

    const rowsToClear = Math.max(existingRange.getNumRows(), values.length);
    sheet.getRange(startRow, col, rowsToClear, 1).clearContent().clearDataValidations();

    if (startRow > 1) {
      sheet.getRange(startRow - 1, col).setValue(header);
    }
  } else {
    col = findCatalogHeaderColumn_(sheet, header);

    if (!col) {
      col = Math.max(sheet.getLastColumn() + 1, 1);
      sheet.getRange(1, col).setValue(header);
    }

    sheet.getRange(2, col, Math.max(values.length, 20), 1).clearContent().clearDataValidations();
  }

  const output = values.map(value => [value]);
  const targetRange = sheet.getRange(startRow, col, output.length, 1);

  targetRange.setValues(output);
  ss.setNamedRange(rangeName, targetRange);

  sheet.getRange(1, col).setFontWeight('bold');
  sheet.autoResizeColumn(col);
}


function findCatalogHeaderColumn_(sheet, header) {
  const lastCol = sheet.getLastColumn();

  if (lastCol < 1) {
    return null;
  }

  const headers = sheet
    .getRange(1, 1, 1, lastCol)
    .getValues()[0]
    .map(value => String(value).trim().toLowerCase());

  const target = String(header).trim().toLowerCase();
  const index = headers.indexOf(target);

  return index >= 0 ? index + 1 : null;
}


function verificarMetas_M1_Catalogos() {
  const ss = SpreadsheetApp.getActiveSpreadsheet();

  const rangeNames = [
    'cat_tipo_meta',
    'cat_prioridad_meta',
    'cat_tipo_movimiento_meta',
    'cat_estado_meta'
  ];

  rangeNames.forEach(rangeName => {
    const namedRange = ss.getNamedRanges().find(item => item.getName() === rangeName);

    if (!namedRange) {
      Logger.log(rangeName + ': NO EXISTE');
      return;
    }

    const range = namedRange.getRange();
    const values = range.getValues().flat().filter(String);

    Logger.log(rangeName + ': OK → ' + range.getA1Notation() + ' → ' + values.join(', '));
  });
}


