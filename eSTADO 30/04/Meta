function verificarColumnaMetaEnHoja_(ss, sheetName) {
  const sheet = ss.getSheetByName(sheetName);

  if (!sheet) {
    Logger.log(sheetName + ': NO EXISTE');
    return;
  }

  const etiquetaCol = buscarColumnaPorEncabezadoMetas_(sheet, 'Etiqueta');
  const metaCol = buscarColumnaPorEncabezadoMetas_(sheet, 'Meta');

  if (!etiquetaCol) {
    Logger.log(sheetName + ': NO se encontró Etiqueta');
    return;
  }

  if (!metaCol) {
    Logger.log(sheetName + ': NO se encontró Meta');
    return;
  }

  const validacion = sheet.getRange(2, metaCol).getDataValidation() ? 'OK' : 'SIN VALIDACIÓN';

  Logger.log(sheetName + ': Etiqueta columna ' + etiquetaCol);
  Logger.log(sheetName + ': Meta columna ' + metaCol);
  Logger.log(sheetName + ': Validación Meta: ' + validacion);

  if (metaCol === etiquetaCol + 1) {
    Logger.log(sheetName + ': OK → Meta está justo después de Etiqueta');
  } else {
    Logger.log(sheetName + ': REVISAR → Meta existe, pero no está justo después de Etiqueta');
  }
}
