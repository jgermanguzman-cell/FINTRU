function setupMetas_M5_Calculos() {
  const ss = SpreadsheetApp.getActiveSpreadsheet();

  const shMetas = ss.getSheetByName("Metas");
  const shAportes = ss.getSheetByName("Aportes_Metas");
  const shMovimientos = ss.getSheetByName("Movimientos");

  if (!shMetas || !shAportes || !shMovimientos) {
    throw new Error("Faltan hojas requeridas: Metas, Aportes_Metas o Movimientos.");
  }

  validarColumnasM5_(shMetas, shAportes, shMovimientos);

  const headersExtra = [
    {
      col: 14,
      name: "Avance %"
    },
    {
      col: 15,
      name: "Disponible / avance"
    },
    {
      col: 16,
      name: "Estado avance"
    }
  ];

  headersExtra.forEach(item => {
    shMetas.getRange(1, item.col).setValue(item.name);
  });

  shMetas.getRange(1, 1, 1, 16)
    .setFontWeight("bold")
    .setBackground("#f3f4f6");

  const startRow = 2;
  const numRows = 999;

  const formulasSaldo = [];
  const formulasAporteMensual = [];
  const formulasAvance = [];
  const formulasDisponibleAvance = [];
  const formulasEstadoAvance = [];

  for (let i = 0; i < numRows; i++) {
    const row = startRow + i;

    const baseVirtual = construirFormulaBaseVirtualM5_(row);

    const formulaSaldo = `=IF($B${row}="";"";SWITCH($C${row};"Consumo";${baseVirtual}-IFERROR(SUMIFS(Movimientos!$F:$F;Movimientos!$O:$O;$B${row};Movimientos!$M:$M;"Egreso");0);"Deuda";${baseVirtual}+IFERROR(SUMIFS(Movimientos!$F:$F;Movimientos!$O:$O;$B${row};Movimientos!$M:$M;"Transferencia");0);${baseVirtual}+IFERROR(SUMIFS(Movimientos!$F:$F;Movimientos!$O:$O;$B${row};Movimientos!$L:$L;"Patrimonio");0)))`;

    const formulaAporteMensual = `=IF($B${row}="";"";IF(OR($G${row}="";$G${row}<=0);"";IF($K${row}="";MAX(0;$G${row}-$I${row});IF($K${row}<TODAY();MAX(0;$G${row}-$I${row});MAX(0;($G${row}-$I${row})/MAX(1;DATEDIF(TODAY();$K${row};"M")+1))))))`;

    const formulaAvance = `=IF($B${row}="";"";IFERROR(MIN($I${row}/$G${row};1);""))`;

    const formulaDisponibleAvance = `=IF($B${row}="";"";IF($C${row}="Consumo";TEXT($I${row};"$#,##0")&" disponibles";TEXT($N${row};"0%")&" avance"))`;

    const formulaEstadoAvance = `=IF($B${row}="";"";IF($M${row}<>"Activa";"Meta no activa";IF(OR($G${row}="";$G${row}<=0);"Sin objetivo";IF($N${row}>=1;"Completada";IF(AND($K${row}<>"";$K${row}<TODAY());"Atrasada";IF($N${row}>=0,7;"En buen camino";IF($N${row}>=0,3;"En progreso";"Arrancando")))))))`;

    formulasSaldo.push([formulaSaldo]);
    formulasAporteMensual.push([formulaAporteMensual]);
    formulasAvance.push([formulaAvance]);
    formulasDisponibleAvance.push([formulaDisponibleAvance]);
    formulasEstadoAvance.push([formulaEstadoAvance]);
  }

  shMetas.getRange(startRow, 9, numRows, 1).setFormulas(formulasSaldo); // I
  shMetas.getRange(startRow, 10, numRows, 1).setFormulas(formulasAporteMensual); // J
  shMetas.getRange(startRow, 14, numRows, 1).setFormulas(formulasAvance); // N
  shMetas.getRange(startRow, 15, numRows, 1).setFormulas(formulasDisponibleAvance); // O
  shMetas.getRange(startRow, 16, numRows, 1).setFormulas(formulasEstadoAvance); // P

  aplicarFormatoMetasM5_(shMetas);

  SpreadsheetApp.flush();
}


function construirFormulaBaseVirtualM5_(row) {
  return `($H${row}+IFERROR(SUMIFS(Aportes_Metas!$E:$E;Aportes_Metas!$B:$B;$B${row};Aportes_Metas!$D:$D;"Asignación virtual");0)-IFERROR(SUMIFS(Aportes_Metas!$E:$E;Aportes_Metas!$B:$B;$B${row};Aportes_Metas!$D:$D;"Retiro virtual");0)+IFERROR(SUMIFS(Aportes_Metas!$E:$E;Aportes_Metas!$B:$B;$B${row};Aportes_Metas!$D:$D;"Ajuste manual");0))`;
}

function validarColumnasM5_(shMetas, shAportes, shMovimientos) {
  const checks = [
    {
      sheet: shMetas,
      expected: [
        ["ID_Meta", 1],
        ["Nombre", 2],
        ["Tipo meta", 3],
        ["Categoría relacionada", 4],
        ["Cuenta referencia", 5],
        ["Deuda relacionada", 6],
        ["Monto objetivo", 7],
        ["Saldo inicial / asignado", 8],
        ["Saldo calculado", 9],
        ["Aporte mensual sugerido", 10],
        ["Fecha objetivo", 11],
        ["Prioridad", 12],
        ["Estado", 13]
      ]
    },
    {
      sheet: shAportes,
      expected: [
        ["Fecha", 1],
        ["Meta", 2],
        ["Cuenta referencia", 3],
        ["Tipo movimiento meta", 4],
        ["Monto", 5]
      ]
    },
    {
      sheet: shMovimientos,
      expected: [
        ["COP", 6],
        ["Categoría", 12],
        ["Naturaleza", 13],
        ["Meta", 15]
      ]
    }
  ];

  checks.forEach(group => {
    group.expected.forEach(item => {
      const header = item[0];
      const expectedCol = item[1];
      const realCol = buscarColumnaPorEncabezadoMetas_(group.sheet, header);

      if (realCol !== expectedCol) {
        throw new Error(
          "M5 detenido. En hoja " +
          group.sheet.getName() +
          ", la columna '" +
          header +
          "' debería estar en posición " +
          expectedCol +
          ", pero está en " +
          realCol +
          ". Revisa antes de aplicar fórmulas."
        );
      }
    });
  });
}


