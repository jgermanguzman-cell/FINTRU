function obtenerFilaBloqueRecordatoriosDashboardData_(sheet) {
  const lastRow = Math.max(sheet.getLastRow(), 1);

  const values = sheet.getRange(1, 1, lastRow, 1).getValues().flat();

  for (let i = 0; i < values.length; i++) {
    if (String(values[i]).trim().toUpperCase() === "RECORDATORIOS") {
      return i + 1;
    }
  }

  return lastRow + 3;
}


function verificarMetas_M14A_DashboardDataRecordatorios() {
