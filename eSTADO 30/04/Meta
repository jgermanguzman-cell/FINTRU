function asegurarColumnaMetaDespuesDeEtiqueta_(ss, sheetName) {
  const sheet = ss.getSheetByName(sheetName);

  if (!sheet) {
    throw new Error('No existe la hoja: ' + sheetName);
  }

  const etiquetaCol = buscarColumnaPorEncabezadoMetas_(sheet, 'Etiqueta');
  const metaColExistente = buscarColumnaPorEncabezadoMetas_(sheet, 'Meta');

  if (!etiquetaCol) {
    throw new Error('No se encontró la columna Etiqueta en la hoja: ' + sheetName);
  }

  if (metaColExistente) {
    Logger.log(sheetName + ': la columna Meta ya existe en columna ' + metaColExistente);
    return {
      sheet,
      metaCol: metaColExistente,
      created: false
    };
  }

  sheet.insertColumnAfter(etiquetaCol);

  const metaCol = etiquetaCol + 1;
  sheet.getRange(1, metaCol).setValue('Meta');

  sheet.getRange(1, metaCol)
    .setFontWeight('bold')
    .setBackground('#f3f4f6');

  sheet.setColumnWidth(metaCol, 180);

  Logger.log(sheetName + ': columna Meta creada en columna ' + metaCol);

  return {
    sheet,
    metaCol,
    created: true
  };
}


function aplicarValidacionMetaActivaEnColumna_(sheet, columnNumber, metasActivas) {
  const maxRows = 1000;
  const startRow = 2;

  const range = sheet.getRange(startRow, columnNumber, maxRows, 1);

  if (!metasActivas || metasActivas.length === 0) {
    Logger.log('No hay metas activas para validar en hoja: ' + sheet.getName());
    range.clearDataValidations();
    return;
  }

  const uniqueMetas = [...new Set(metasActivas.filter(String))];

  const rule = SpreadsheetApp.newDataValidation()
    .requireValueInList(uniqueMetas, true)
    .setAllowInvalid(false)
    .build();

  range.setDataValidation(rule);
}


function buscarColumnaPorEncabezadoMetas_(sheet, headerName) {
  const lastCol = sheet.getLastColumn();

  if (lastCol < 1) return null;

  const headers = sheet.getRange(1, 1, 1, lastCol).getValues()[0];

  const target = normalizarTextoMetas_(headerName);

  const aliases = {
    [normalizarTextoMetas_("Saldo inicial")]: [
      normalizarTextoMetas_("Saldo inicial"),
      normalizarTextoMetas_("Saldo inicial / asignado")
    ],
    [normalizarTextoMetas_("Saldo inicial / asignado")]: [
      normalizarTextoMetas_("Saldo inicial"),
      normalizarTextoMetas_("Saldo inicial / asignado")
    ]
  };

  const validTargets = aliases[target] || [target];

  for (let i = 0; i < headers.length; i++) {
    const currentHeader = normalizarTextoMetas_(headers[i]);

    if (validTargets.includes(currentHeader)) {
      return i + 1;
    }
  }

  return null;
}


function normalizarTextoMetas_(value) {
  return String(value || '')
    .trim()
    .toLowerCase()
    .normalize('NFD')
    .replace(/[\u0300-\u036f]/g, '');
}


function verificarMetas_M4A_ColumnasMeta() {
  const ss = SpreadsheetApp.getActiveSpreadsheet();

  verificarColumnaMetaEnHoja_(ss, 'Presupuesto');
  verificarColumnaMetaEnHoja_(ss, 'Movimientos');
