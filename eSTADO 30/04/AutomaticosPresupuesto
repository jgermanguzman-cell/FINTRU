  }
}


function crearHeaderMap_(headers) {
  const map = {};

  headers.forEach((header, index) => {
    const key = normalizarHeader_(header);
    if (key) {
      map[key] = index;
    }
  });

  return map;
}


function obtenerIndiceHeader_(map, posiblesNombres) {
  for (const nombre of posiblesNombres) {
    const key = normalizarHeader_(nombre);
    if (Object.prototype.hasOwnProperty.call(map, key)) {
      return map[key];
    }
  }

  return null;
}


function leerCampo_(row, map, posiblesNombres) {
  const index = obtenerIndiceHeader_(map, posiblesNombres);
  return index === null ? "" : row[index];
}


function escribirCampo_(row, map, posiblesNombres, value) {
  const index = obtenerIndiceHeader_(map, posiblesNombres);
  if (index !== null) {
    row[index] = value;
  }
}


function normalizarHeader_(value) {
  return String(value || "")
    .trim()
    .toLowerCase()
    .normalize("NFD")
    .replace(/[\u0300-\u036f]/g, "")
    .replace(/_/g, " ")
    .replace(/\s+/g, " ");
}
function obtenerPrimeraFilaVaciaPorConcepto_(shMovimientos, movimientosMap) {
  const conceptoCol = obtenerIndiceHeader_(movimientosMap, ["Concepto"]);

  if (conceptoCol === null) {
    throw new Error("No se encontró la columna Concepto en Movimientos.");
  }

  const startRow = 2;
  const maxRows = shMovimientos.getMaxRows();
  const numRows = maxRows - 1;

  const conceptos = shMovimientos
    .getRange(startRow, conceptoCol + 1, numRows, 1)
    .getValues()
    .flat();

  for (let i = 0; i < conceptos.length; i++) {
    if (String(conceptos[i]).trim() === "") {
      return startRow + i;
    }
  }

  const nuevaFila = maxRows + 1;
  shMovimientos.insertRowsAfter(maxRows, 1);
  return nuevaFila;
}
function monitorearAutomaticos() {
  const ss = SpreadsheetApp.getActiveSpreadsheet();

  const shPresupuesto = ss.getSheetByName("Presupuesto");
  const shMovimientos = ss.getSheetByName("Movimientos");

  if (!shPresupuesto || !shMovimientos) {
    throw new Error("Faltan hojas requeridas: Presupuesto o Movimientos.");
  }

  let shMonitor = ss.getSheetByName("Monitor Automáticos");
  if (!shMonitor) {
    shMonitor = ss.insertSheet("Monitor Automáticos");
  }

  shMonitor.clearContents();

  shMonitor.getRange(1, 1, 1, 11).setValues([[
    "Fila Presupuesto",
    "Concepto",
    "Monto",
    "Día de Pago",
    "Tipo",
    "Activo",
    "Recurrencia",
    "Próxima ejecución",
    "Ref del mes",
    "Estado",
    "Motivo"
  ]]);

  const hoy = new Date();
  hoy.setHours(0, 0, 0, 0);

  const anioActual = hoy.getFullYear();
  const mesActualIndex = hoy.getMonth(); // 0-11

  const presupuestoLastRow = shPresupuesto.getLastRow();
  const presupuestoLastCol = shPresupuesto.getLastColumn();

  if (presupuestoLastRow < 2) return;

  const presupuestoHeaders = shPresupuesto
    .getRange(1, 1, 1, presupuestoLastCol)
    .getValues()[0];

  const presupuestoMap = crearHeaderMap_(presupuestoHeaders);

  const presupuestoData = shPresupuesto
    .getRange(2, 1, presupuestoLastRow - 1, presupuestoLastCol)
    .getValues();

  const movimientosLastRow = shMovimientos.getLastRow();
  const movimientosLastCol = shMovimientos.getLastColumn();

  const movimientosHeaders = shMovimientos
    .getRange(1, 1, 1, movimientosLastCol)
    .getValues()[0];

  const movimientosMap = crearHeaderMap_(movimientosHeaders);

  const refColMovimientos = obtenerIndiceHeader_(movimientosMap, [
    "Ref_Presupuesto",
    "Ref Presupuesto"
  ]);

  const movimientosRefs = refColMovimientos !== null && movimientosLastRow >= 2
    ? shMovimientos
        .getRange(2, refColMovimientos + 1, movimientosLastRow - 1, 1)
        .getValues()
        .flat()
        .map(String)
    : [];

  const filasMonitor = [];

  presupuestoData.forEach((row, index) => {
    const filaPresupuesto = index + 2;

    const concepto = leerCampo_(row, presupuestoMap, ["Concepto"]);
    const monto = leerCampo_(row, presupuestoMap, ["Monto"]);
    const diaPagoRaw = leerCampo_(row, presupuestoMap, ["Día de Pago", "Dia de Pago"]);
    const tipo = String(leerCampo_(row, presupuestoMap, ["Tipo"])).trim();
    const activo = String(leerCampo_(row, presupuestoMap, ["Activo"])).trim();
    const recurrencia = String(leerCampo_(row, presupuestoMap, ["Recurrencia"])).trim();

    if (!concepto) return;

    let diaPago = "";

    if (diaPagoRaw instanceof Date) {
      diaPago = diaPagoRaw.getDate();
    } else {
      diaPago = Number(diaPagoRaw);
    }

    let fechaEsteMes = "";
    let fechaProxima = "";
    let periodoRef = "";
    let refPresupuesto = "";
    let yaEjecutadoEsteMes = false;

    if (diaPago) {
      fechaEsteMes = obtenerFechaEjecucionMensual_(anioActual, mesActualIndex, diaPago);

      const periodoEsteMes = obtenerPeriodoDesdeFecha_(fechaEsteMes);
      const refEsteMes = `PRESUPUESTO-F${filaPresupuesto}-${periodoEsteMes}`;
      yaEjecutadoEsteMes = movimientosRefs.includes(refEsteMes);

      if (fechaEsteMes < hoy || yaEjecutadoEsteMes) {
        const fechaSiguienteMes = obtenerFechaEjecucionMensual_(
          new Date(anioActual, mesActualIndex + 1, 1).getFullYear(),
          new Date(anioActual, mesActualIndex + 1, 1).getMonth(),
          diaPago
        );

        fechaProxima = fechaSiguienteMes;
      } else {
        fechaProxima = fechaEsteMes;
      }

      periodoRef = obtenerPeriodoDesdeFecha_(fechaProxima);
      refPresupuesto = `PRESUPUESTO-F${filaPresupuesto}-${periodoRef}`;
    }

    let estado = "";
    let motivo = "";

    if (activo !== "Activo") {
      estado = "No se ejecuta";
      motivo = "No está activo";
    } else if (tipo !== "Automático") {
      estado = "No se ejecuta";
      motivo = "No es automático";
    } else if (recurrencia !== "Mensual") {
      estado = "No se ejecuta";
      motivo = "No es mensual";
    } else if (!diaPago) {
      estado = "No se ejecuta";
      motivo = "Día de pago vacío o inválido";
    } else if (yaEjecutadoEsteMes) {
      estado = "Ya ejecutado este mes";
      motivo = "La próxima ejecución será el siguiente mes";
    } else if (fechaEsteMes.getTime() === hoy.getTime()) {
      estado = "Se ejecuta hoy";
      motivo = "Cumple condiciones";
    } else if (fechaEsteMes > hoy) {
      estado = "Pendiente este mes";
      motivo = `Se ejecutará el día ${fechaEsteMes.getDate()} de este mes`;
    } else {
      estado = "Pendiente próximo mes";
      motivo = `El día de pago de este mes ya pasó. Próxima ejecución: ${fechaProxima.getDate()}/${fechaProxima.getMonth() + 1}/${fechaProxima.getFullYear()}`;
    }

    filasMonitor.push([
      filaPresupuesto,
      concepto,
      monto,
      diaPago,
      tipo,
      activo,
      recurrencia,
      fechaProxima,
      refPresupuesto,
      estado,
      motivo
    ]);
  });

  if (filasMonitor.length > 0) {
    shMonitor.getRange(2, 1, filasMonitor.length, 11).setValues(filasMonitor);
  }
}


function obtenerFechaEjecucionMensual_(anio, mesIndex, diaPago) {
  const ultimoDiaMes = new Date(anio, mesIndex + 1, 0).getDate();
  const diaEjecucion = Math.min(Number(diaPago), ultimoDiaMes);

  const fecha = new Date(anio, mesIndex, diaEjecucion);
  fecha.setHours(0, 0, 0, 0);

  return fecha;
}


function obtenerPeriodoDesdeFecha_(fecha) {
  const anio = fecha.getFullYear();
  const mes = fecha.getMonth() + 1;

  return `${anio}-${String(mes).padStart(2, "0")}`;
}
