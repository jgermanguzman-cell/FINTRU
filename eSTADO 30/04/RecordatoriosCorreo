function diagnosticarRecordatoriosCorreoHoy() {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const shPresupuesto = ss.getSheetByName("Presupuesto");

  if (!shPresupuesto) {
    throw new Error("No existe la hoja Presupuesto.");
  }

  const emailDestino = obtenerEmailRecordatorios_();
  Logger.log("Email destino: " + (emailDestino || "NO CONFIGURADO"));

  const hoy = new Date();
  hoy.setHours(0, 0, 0, 0);

  const diaHoy = hoy.getDate();
  const periodo = obtenerPeriodoRecordatorios_(hoy);

  Logger.log("Hoy: " + Utilities.formatDate(hoy, ss.getSpreadsheetTimeZone(), "dd/MM/yyyy"));
  Logger.log("Día hoy: " + diaHoy);
  Logger.log("Periodo: " + periodo);

  const lastRow = shPresupuesto.getLastRow();
  const lastCol = shPresupuesto.getLastColumn();

  if (lastRow < 2) {
    Logger.log("No hay filas en Presupuesto.");
    return;
  }

  const headers = shPresupuesto.getRange(1, 1, 1, lastCol).getValues()[0];
  const map = crearHeaderMapRecordatorios_(headers);
  const data = shPresupuesto.getRange(2, 1, lastRow - 1, lastCol).getValues();

  const shLog = obtenerHojaLogRecordatorios_();
  const refsEnviadas = obtenerRefsRecordatoriosEnviadas_(shLog);

  let candidatos = 0;
  let enviadosHoy = 0;
  let bloqueadosPorLog = 0;

  data.forEach((row, index) => {
    const filaPresupuesto = index + 2;

    const concepto = String(leerCampoRecordatorios_(row, map, ["Concepto"]) || "").trim();
    const tipo = String(leerCampoRecordatorios_(row, map, ["Tipo"]) || "").trim();
    const activo = String(leerCampoRecordatorios_(row, map, ["Activo"]) || "").trim();
    const recurrencia = String(leerCampoRecordatorios_(row, map, ["Recurrencia"]) || "").trim();
    const diaPagoRaw = leerCampoRecordatorios_(row, map, ["Día de Pago", "Dia de Pago"]);

    if (!concepto) return;
    if (tipo !== "Recordatorio") return;
    if (activo !== "Activo") return;
    if (recurrencia !== "Mensual") return;

    candidatos++;

    let diaPago = "";

    if (diaPagoRaw instanceof Date) {
      diaPago = diaPagoRaw.getDate();
    } else {
      diaPago = Number(diaPagoRaw);
    }

    const refRecordatorio = `RECORDATORIO-F${filaPresupuesto}-${periodo}`;
    const yaEnviado = refsEnviadas.includes(refRecordatorio);

    Logger.log("----");
    Logger.log("Fila " + filaPresupuesto + ": " + concepto);
    Logger.log("Día de pago: " + diaPago);
    Logger.log("Ref: " + refRecordatorio);
    Logger.log("Ya enviado en log: " + (yaEnviado ? "Sí" : "No"));

    if (yaEnviado) {
      bloqueadosPorLog++;
    }

    if (diaPago === diaHoy && !yaEnviado) {
      enviadosHoy++;
      Logger.log("Estado: SE ENVIARÍA HOY");
    } else if (diaPago !== diaHoy) {
      Logger.log("Estado: NO se envía hoy porque el día de pago no coincide.");
    } else if (yaEnviado) {
      Logger.log("Estado: NO se envía porque ya está en Log Recordatorios.");
    }
  });

  Logger.log("==== RESUMEN ====");
  Logger.log("Recordatorios candidatos: " + candidatos);
  Logger.log("Se enviarían hoy: " + enviadosHoy);
  Logger.log("Bloqueados por Log Recordatorios: " + bloqueadosPorLog);
}


function enviarCorreoPruebaPrimerRecordatorio() {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const shRecordatorios = ss.getSheetByName("Recordatorios");

  if (!shRecordatorios) {
    throw new Error("No existe la hoja Recordatorios.");
  }

  const lastRow = shRecordatorios.getLastRow();

  if (lastRow < 2) {
    throw new Error("No hay recordatorios en la hoja Recordatorios.");
  }

  const emailDestino = obtenerEmailRecordatorios_();

  if (!emailDestino) {
    throw new Error("No hay email configurado.");
  }

  const recordatorio = {
    concepto: shRecordatorios.getRange(2, 1).getValue(),
    monto: shRecordatorios.getRange(2, 2).getValue(),
    cop: shRecordatorios.getRange(2, 2).getValue(),
    metodoPago: shRecordatorios.getRange(2, 3).getValue(),
    meta: shRecordatorios.getRange(2, 4).getValue()
  };

  const cuerpo = construirCuerpoRecordatorios_([recordatorio], new Date());

  GmailApp.sendEmail(
    emailDestino,
    "Prueba recordatorio Fintru",
    cuerpo
  );

  Logger.log("Correo de prueba con primer recordatorio enviado a: " + emailDestino);
}
