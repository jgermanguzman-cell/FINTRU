function enviarRecordatoriosHoy() {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const shPresupuesto = ss.getSheetByName("Presupuesto");

  if (!shPresupuesto) {
    throw new Error("No existe la hoja Presupuesto.");
  }

  const emailDestino = obtenerEmailRecordatorios_();

  if (!emailDestino) {
    throw new Error("No hay email configurado para enviar recordatorios.");
  }

  const hoy = new Date();
  hoy.setHours(0, 0, 0, 0);

  const diaHoy = hoy.getDate();
  const anio = hoy.getFullYear();
  const mesIndex = hoy.getMonth();
  const periodo = obtenerPeriodoRecordatorios_(hoy);
  const ultimoDiaMes = new Date(anio, mesIndex + 1, 0).getDate();

  const lastRow = shPresupuesto.getLastRow();
  const lastCol = shPresupuesto.getLastColumn();

  if (lastRow < 2) return;

  const headers = shPresupuesto.getRange(1, 1, 1, lastCol).getValues()[0];
  const map = crearHeaderMapRecordatorios_(headers);

  const data = shPresupuesto.getRange(2, 1, lastRow - 1, lastCol).getValues();

  const shLog = obtenerHojaLogRecordatorios_();
  const refsEnviadas = obtenerRefsRecordatoriosEnviadas_(shLog);

  const recordatorios = [];

  data.forEach((row, index) => {
    const filaPresupuesto = index + 2;

    const concepto = leerCampoRecordatorios_(row, map, ["Concepto"]);
    const monto = leerCampoRecordatorios_(row, map, ["Monto"]);
    const diaPagoRaw = leerCampoRecordatorios_(row, map, ["Día de Pago", "Dia de Pago"]);
    const metodoPago = leerCampoRecordatorios_(row, map, ["Método de Pago", "Metodo de Pago"]);
    const destino = leerCampoRecordatorios_(row, map, ["Destino"]);
    const destinoTC = leerCampoRecordatorios_(row, map, ["Destino_TC", "Destino TC"]);
    const destinoDeuda = leerCampoRecordatorios_(row, map, ["Destino_Deuda", "Destino Deuda"]);
    const moneda = leerCampoRecordatorios_(row, map, ["Moneda"]);
    const cop = leerCampoRecordatorios_(row, map, ["COP"]);
    const tipo = String(leerCampoRecordatorios_(row, map, ["Tipo"])).trim();
    const categoria = leerCampoRecordatorios_(row, map, ["Categoria", "Categoría"]);
    const naturaleza = leerCampoRecordatorios_(row, map, ["Naturaleza"]);
    const etiqueta = leerCampoRecordatorios_(row, map, ["Etiqueta"]);
    const meta = leerCampoRecordatorios_(row, map, ["Meta"]);
    const activo = String(leerCampoRecordatorios_(row, map, ["Activo"])).trim();
    const recurrencia = String(leerCampoRecordatorios_(row, map, ["Recurrencia"])).trim();

    if (!concepto) return;
    if (activo !== "Activo") return;
    if (tipo !== "Recordatorio") return;
    if (recurrencia !== "Mensual") return;

    let diaPago = "";

    if (diaPagoRaw instanceof Date) {
      diaPago = diaPagoRaw.getDate();
    } else {
      diaPago = Number(diaPagoRaw);
    }

    if (!diaPago) return;

    const diaEjecucion = Math.min(diaPago, ultimoDiaMes);

    if (diaEjecucion !== diaHoy) return;

    const refRecordatorio = `RECORDATORIO-F${filaPresupuesto}-${periodo}`;

    if (refsEnviadas.includes(refRecordatorio)) return;

    recordatorios.push({
      filaPresupuesto,
      refRecordatorio,
      concepto,
      monto,
      moneda,
      cop,
      metodoPago,
      destino,
      destinoTC,
      destinoDeuda,
      categoria,
      naturaleza,
      etiqueta,
      meta
    });
  });

  if (recordatorios.length === 0) return;

  const asunto = `Recordatorios financieros de hoy - ${Utilities.formatDate(hoy, ss.getSpreadsheetTimeZone(), "dd/MM/yyyy")}`;
  const cuerpo = construirCuerpoRecordatorios_(recordatorios, hoy);

  GmailApp.sendEmail(emailDestino, asunto, cuerpo);

  const ahora = new Date();

  const logRows = recordatorios.map(item => [
    ahora,
    periodo,
    item.filaPresupuesto,
    item.concepto,
    item.refRecordatorio,
    emailDestino,
    "Enviado"
  ]);

  shLog.getRange(shLog.getLastRow() + 1, 1, logRows.length, 7).setValues(logRows);
}


function crearTriggerRecordatoriosDiario() {
  eliminarTriggerRecordatoriosDiario();

  ScriptApp.newTrigger("enviarRecordatoriosHoy")
    .timeBased()
    .everyDays(1)
    .atHour(8)
    .create();
}


function eliminarTriggerRecordatoriosDiario() {
  const triggers = ScriptApp.getProjectTriggers();

  triggers.forEach(trigger => {
    if (trigger.getHandlerFunction() === "enviarRecordatoriosHoy") {
      ScriptApp.deleteTrigger(trigger);
    }
  });
}


function probarRecordatoriosHoy() {
  enviarRecordatoriosHoy();
}


function configurarEmailRecordatorios() {
  const ui = SpreadsheetApp.getUi();

  const response = ui.prompt(
    "Configurar email de recordatorios",
    "Escribe el correo al que quieres recibir los recordatorios:",
    ui.ButtonSet.OK_CANCEL
  );

  if (response.getSelectedButton() !== ui.Button.OK) return;

  const email = String(response.getResponseText()).trim();

  if (!email) {
    ui.alert("No se guardó ningún correo.");
    return;
  }

  PropertiesService.getDocumentProperties().setProperty("EMAIL_RECORDATORIOS", email);

  ui.alert(`Correo guardado: ${email}`);
}


function monitorearRecordatorios() {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const shPresupuesto = ss.getSheetByName("Presupuesto");

  if (!shPresupuesto) {
    throw new Error("No existe la hoja Presupuesto.");
  }

  let shMonitor = ss.getSheetByName("Monitor Recordatorios");
  if (!shMonitor) {
    shMonitor = ss.insertSheet("Monitor Recordatorios");
  }

  shMonitor.clearContents();

  shMonitor.getRange(1, 1, 1, 11).setValues([[
    "Fila Presupuesto",
    "Concepto",
    "Monto",
    "Día de Pago",
    "Tipo",
    "Activo",
    "Recurrencia",
    "Próximo recordatorio",
    "Ref",
    "Estado",
    "Motivo"
  ]]);

  const hoy = new Date();
  hoy.setHours(0, 0, 0, 0);

  const anioActual = hoy.getFullYear();
  const mesActualIndex = hoy.getMonth();

  const lastRow = shPresupuesto.getLastRow();
  const lastCol = shPresupuesto.getLastColumn();

  if (lastRow < 2) return;

  const headers = shPresupuesto.getRange(1, 1, 1, lastCol).getValues()[0];
  const map = crearHeaderMapRecordatorios_(headers);

  const data = shPresupuesto.getRange(2, 1, lastRow - 1, lastCol).getValues();

  const shLog = obtenerHojaLogRecordatorios_();
  const refsEnviadas = obtenerRefsRecordatoriosEnviadas_(shLog);

  const filasMonitor = [];

  data.forEach((row, index) => {
    const filaPresupuesto = index + 2;

    const concepto = leerCampoRecordatorios_(row, map, ["Concepto"]);
    const monto = leerCampoRecordatorios_(row, map, ["Monto"]);
    const diaPagoRaw = leerCampoRecordatorios_(row, map, ["Día de Pago", "Dia de Pago"]);
    const tipo = String(leerCampoRecordatorios_(row, map, ["Tipo"])).trim();
    const activo = String(leerCampoRecordatorios_(row, map, ["Activo"])).trim();
    const recurrencia = String(leerCampoRecordatorios_(row, map, ["Recurrencia"])).trim();

    if (!concepto) return;

    let diaPago = "";

    if (diaPagoRaw instanceof Date) {
      diaPago = diaPagoRaw.getDate();
    } else {
      diaPago = Number(diaPagoRaw);
    }

    let fechaEsteMes = "";
    let fechaProxima = "";
    let ref = "";
    let yaEnviadoEsteMes = false;

    if (diaPago) {
      fechaEsteMes = obtenerFechaRecordatorioMensual_(anioActual, mesActualIndex, diaPago);

      const periodoEsteMes = obtenerPeriodoRecordatorios_(fechaEsteMes);
      const refEsteMes = `RECORDATORIO-F${filaPresupuesto}-${periodoEsteMes}`;
      yaEnviadoEsteMes = refsEnviadas.includes(refEsteMes);

      if (fechaEsteMes < hoy || yaEnviadoEsteMes) {
        const fechaBaseSiguienteMes = new Date(anioActual, mesActualIndex + 1, 1);

        fechaProxima = obtenerFechaRecordatorioMensual_(
          fechaBaseSiguienteMes.getFullYear(),
          fechaBaseSiguienteMes.getMonth(),
          diaPago
        );
      } else {
        fechaProxima = fechaEsteMes;
      }

      const periodoProximo = obtenerPeriodoRecordatorios_(fechaProxima);
      ref = `RECORDATORIO-F${filaPresupuesto}-${periodoProximo}`;
    }

    let estado = "";
    let motivo = "";

    if (activo !== "Activo") {
      estado = "No se envía";
      motivo = "No está activo";
    } else if (tipo !== "Recordatorio") {
      estado = "No se envía";
      motivo = "No es recordatorio";
    } else if (recurrencia !== "Mensual") {
      estado = "No se envía";
      motivo = "No es mensual";
    } else if (!diaPago) {
      estado = "No se envía";
      motivo = "Día de pago vacío o inválido";
    } else if (yaEnviadoEsteMes) {
      estado = "Ya enviado este mes";
      motivo = "El próximo recordatorio será el siguiente mes";
    } else if (fechaEsteMes.getTime() === hoy.getTime()) {
      estado = "Se envía hoy";
      motivo = "Cumple condiciones";
    } else if (fechaEsteMes > hoy) {
      estado = "Pendiente este mes";
      motivo = `Se enviará el día ${fechaEsteMes.getDate()} de este mes`;
    } else {
      estado = "Pendiente próximo mes";
      motivo = `El día de pago de este mes ya pasó. Próximo recordatorio: ${fechaProxima.getDate()}/${fechaProxima.getMonth() + 1}/${fechaProxima.getFullYear()}`;
    }

    filasMonitor.push([
      filaPresupuesto,
      concepto,
      monto,
      diaPago,
      tipo,
      activo,
      recurrencia,
      fechaProxima,
      ref,
      estado,
      motivo
    ]);
  });

  if (filasMonitor.length > 0) {
    shMonitor.getRange(2, 1, filasMonitor.length, 11).setValues(filasMonitor);
  }
}


function obtenerHojaLogRecordatorios_() {
  const ss = SpreadsheetApp.getActiveSpreadsheet();

  let shLog = ss.getSheetByName("Log Recordatorios");

  if (!shLog) {
    shLog = ss.insertSheet("Log Recordatorios");

    shLog.getRange(1, 1, 1, 7).setValues([[
      "Fecha envío",
      "Periodo",
      "Fila Presupuesto",
      "Concepto",
      "Ref",
      "Email",
      "Estado"
    ]]);
  }

  return shLog;
}


function obtenerRefsRecordatoriosEnviadas_(shLog) {
  const lastRow = shLog.getLastRow();

  if (lastRow < 2) return [];

  return shLog
    .getRange(2, 5, lastRow - 1, 1)
    .getValues()
    .flat()
    .map(String);
}


function obtenerEmailRecordatorios_() {
  const props = PropertiesService.getDocumentProperties();
  const emailConfigurado = props.getProperty("EMAIL_RECORDATORIOS");

  if (emailConfigurado) return emailConfigurado;

  const emailActivo = Session.getActiveUser().getEmail();
  if (emailActivo) return emailActivo;

  const emailEfectivo = Session.getEffectiveUser().getEmail();
  if (emailEfectivo) return emailEfectivo;

  return "";
}


function construirCuerpoRecordatorios_(recordatorios, fecha) {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const fechaTexto = Utilities.formatDate(fecha, ss.getSpreadsheetTimeZone(), "dd/MM/yyyy");
  const shRecordatorios = ss.getSheetByName("Recordatorios");
  const urlArchivo = shRecordatorios ? `${ss.getUrl()}#gid=${shRecordatorios.getSheetId()}` : ss.getUrl();

  let cuerpo = "";

  cuerpo += `Hoy tienes ${recordatorios.length} recordatorio(s) financiero(s).\n`;
  cuerpo += `Fecha: ${fechaTexto}\n\n`;

  cuerpo += "Qué debes hacer:\n";
  cuerpo += "1. Realiza el pago, aporte o movimiento correspondiente.\n";
  cuerpo += "2. Abre tu archivo de Fintru.\n";
  cuerpo += "3. Ve a la hoja Recordatorios.\n";
  cuerpo += "4. Marca la casilla “Registrar como pagado”.\n";
  cuerpo += "5. Fintru registrará automáticamente el movimiento y evitará duplicados este mes.\n\n";

  cuerpo += `Abrir hoja Recordatorios: ${urlArchivo}\n\n`;

  cuerpo += "Recordatorios de hoy:\n\n";

  recordatorios.forEach((item, index) => {
    cuerpo += `${index + 1}. ${item.concepto}\n`;
    cuerpo += `Monto: ${formatearMontoRecordatorios_(item.cop || item.monto)} ${item.cop ? "COP" : item.moneda || ""}\n`;

    if (item.metodoPago) {
      cuerpo += `Método de pago: ${item.metodoPago}\n`;
    }

    if (item.destino) {
      cuerpo += `Cuenta / destino: ${item.destino}\n`;
    }

    if (item.destinoTC) {
      cuerpo += `Tarjeta destino: ${item.destinoTC}\n`;
    }

    if (item.destinoDeuda) {
      cuerpo += `Deuda destino: ${item.destinoDeuda}\n`;
    }

    if (item.meta) {
      cuerpo += `Meta asociada: ${item.meta}\n`;
    }

    if (item.categoria) {
      cuerpo += `Categoría: ${item.categoria}\n`;
    }

    if (item.naturaleza) {
      cuerpo += `Naturaleza: ${item.naturaleza}\n`;
    }

    if (item.etiqueta) {
      cuerpo += `Etiqueta: ${item.etiqueta}\n`;
    }

    cuerpo += "\n";
  });

  cuerpo += "Recuerda: este correo no registra el movimiento por sí solo. ";
  cuerpo += "El movimiento queda registrado únicamente cuando marcas el recordatorio como pagado en la hoja Recordatorios.\n\n";

  cuerpo += "Fintru — Tu verdad financiera.\n";

  return cuerpo;
}


function obtenerFechaRecordatorioMensual_(anio, mesIndex, diaPago) {
  const ultimoDiaMes = new Date(anio, mesIndex + 1, 0).getDate();
  const diaEjecucion = Math.min(Number(diaPago), ultimoDiaMes);

  const fecha = new Date(anio, mesIndex, diaEjecucion);
  fecha.setHours(0, 0, 0, 0);

  return fecha;
}


function obtenerPeriodoRecordatorios_(fecha) {
  const anio = fecha.getFullYear();
  const mes = fecha.getMonth() + 1;

  return `${anio}-${String(mes).padStart(2, "0")}`;
}


function formatearMontoRecordatorios_(value) {
  const numero = Number(value);

  if (isNaN(numero)) return value;

  return numero.toLocaleString("es-CO", {
    maximumFractionDigits: 0
  });
}


function crearHeaderMapRecordatorios_(headers) {
  const map = {};

  headers.forEach((header, index) => {
    const key = normalizarHeaderRecordatorios_(header);

    if (key) {
      map[key] = index;
    }
  });

  return map;
}


function leerCampoRecordatorios_(row, map, posiblesNombres) {
  const index = obtenerIndiceHeaderRecordatorios_(map, posiblesNombres);
  return index === null ? "" : row[index];
}


function obtenerIndiceHeaderRecordatorios_(map, posiblesNombres) {
  for (const nombre of posiblesNombres) {
    const key = normalizarHeaderRecordatorios_(nombre);

    if (Object.prototype.hasOwnProperty.call(map, key)) {
      return map[key];
    }
  }

  return null;
}


function normalizarHeaderRecordatorios_(value) {
  return String(value || "")
    .trim()
    .toLowerCase()
    .normalize("NFD")
    .replace(/[\u0300-\u036f]/g, "")
    .replace(/_/g, " ")
    .replace(/\s+/g, " ");
}
